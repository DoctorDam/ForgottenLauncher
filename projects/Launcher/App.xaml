<Application x:Class="Forgotten_Land_Launcher.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Forgotten_Land_Launcher"
             StartupUri="Windows/Login.xaml" Startup="Application_Startup">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary  Source="Styles/Buttons.xaml"></ResourceDictionary>
                <ResourceDictionary  Source="Styles/CheckBoxes.xaml"></ResourceDictionary>
                <ResourceDictionary  Source="Styles/Dropdowns.xaml"></ResourceDictionary>
                <ResourceDictionary  Source="Styles/PasswordBoxes.xaml"></ResourceDictionary>
                <ResourceDictionary  Source="Styles/ProgressBars.xaml"></ResourceDictionary>
                <ResourceDictionary  Source="Styles/ScrollViewers.xaml"></ResourceDictionary>
                <ResourceDictionary  Source="Styles/TextBoxes.xaml"></ResourceDictionary>
                <ResourceDictionary  Source="Styles/ToggleButtons.xaml"></ResourceDictionary>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>