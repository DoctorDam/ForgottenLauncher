<UserControl x:Class="Forgotten_Land_Launcher.Forms.Password_Change_Form"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:properties="clr-namespace:Forgotten_Land_Launcher.Properties"
             xmlns:Spinners="clr-namespace:Forgotten_Land_Launcher.Elements.Spinners"
             xmlns:languages="clr-namespace:Forgotten_Land_Launcher.Languages"
             mc:Ignorable="d" RenderOptions.BitmapScalingMode="HighQuality"
             FontFamily="Fira Sans Condensed">
    <Grid>
        <Border Background="#D8000000" CornerRadius="0,0,0,9" HorizontalAlignment="Left" Width="400">
            <Grid>
                <Image Source="/Forgotten Land Launcher;component/Assets/logos/launcher_server_logo.png" HorizontalAlignment="Center" VerticalAlignment="Top" Width="100" Margin="0,25,0,0"/>
                <StackPanel Width="350" HorizontalAlignment="Center" Margin="0,150,0,50">
                    <Grid>
                        <Grid HorizontalAlignment="Center">
                            <TextBox x:Name="textBoxUsername" Style="{DynamicResource loginTextBox}" Text="{x:Static languages:Lang.login_window_form_textbox_register_username}" GotFocus="TextBox_GotFocus"/>
                            <Image Source="/Forgotten Land Launcher;component/Assets/Icons/icon_people_1_a.png" Width="14" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>
                        <Image x:Name="warningIconUser" HorizontalAlignment="Right" VerticalAlignment="Center" Source="/Forgotten Land Launcher;component/Assets/icons/icon_warning_1_a.png" Width="18" Margin="0,0,20,0" Visibility="Hidden"/>
                    </Grid>
                    <Grid Margin="0,15,0,0">
                        <Grid HorizontalAlignment="Center">
                            <TextBox x:Name="textBoxCode" Style="{DynamicResource loginTextBox}" Text="{x:Static languages:Lang.login_window_form_textbox_recovery_code}" GotFocus="TextBox_GotFocus"/>
                            <Image Source="/Forgotten Land Launcher;component/Assets/Icons/icon_code_1_a.png" Width="14" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>
                        <Image x:Name="warningIconCode" HorizontalAlignment="Right" VerticalAlignment="Center" Source="/Forgotten Land Launcher;component/Assets/icons/icon_warning_1_a.png" Width="18" Margin="0,0,20,0" Visibility="Hidden"/>
                    </Grid>
                    <Grid Margin="0,15,0,0">
                        <Grid HorizontalAlignment="Center">
                            <PasswordBox x:Name="textBoxPassword1" Style="{DynamicResource loginPasswordBox}" Password="Password1" GotFocus="TextBox_GotFocus"/>
                            <Image Source="/Forgotten Land Launcher;component/Assets/Icons/icon_lock_1_a.png" Width="14" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>
                        <Image x:Name="warningIconPass1" HorizontalAlignment="Right" VerticalAlignment="Center" Source="/Forgotten Land Launcher;component/Assets/icons/icon_warning_1_a.png" Width="18" Margin="0,0,20,0" Visibility="Hidden"/>
                    </Grid>
                    <Grid Margin="0,15,0,0">
                        <Grid HorizontalAlignment="Center">
                            <PasswordBox x:Name="textBoxPassword2" Style="{DynamicResource loginPasswordBox}" Password="Password2" GotFocus="TextBox_GotFocus"/>
                            <Image Source="/Forgotten Land Launcher;component/Assets/Icons/icon_lock_1_a.png" Width="14" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>
                        <Image x:Name="warningIconPass2" HorizontalAlignment="Right" VerticalAlignment="Center" Source="/Forgotten Land Launcher;component/Assets/icons/icon_warning_1_a.png" Width="18" Margin="0,0,20,0" Visibility="Hidden"/>
                    </Grid>
                    <Button x:Name="btnChangePassword" Style="{DynamicResource loginRegisterButton}" Content="{x:Static languages:Lang.login_window_button_change_password}" Margin="0,20,0,0" Click="btnChangePW_Click"/>
                    <Viewbox x:Name="registerSpinner" Height="40" Margin="0,15,0,0" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed">
                        <Spinners:Dotted_Spinner HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Viewbox>
                    <Grid Margin="0,20,0,0" Width="300">
                        <Border BorderThickness="0,0,0,1" BorderBrush="#FF3C3C3C" Width="70" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <TextBlock Text="{x:Static languages:Lang.login_window_form_divider_placeholder_2}" FontSize="14" Margin="0,-5,0,0" HorizontalAlignment="Center" Foreground="#FF848484" VerticalAlignment="Center"/>
                        <Border BorderThickness="0,0,0,1" BorderBrush="#FF3C3C3C" Width="70" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <Button x:Name="btnBackToSignIn" Style="{DynamicResource btnTosLink}" Content="{x:Static languages:Lang.login_window_button_other_back_to_sign_in}" Margin="0,15,0,0" HorizontalAlignment="Center" Click="btnBackToSignIn_Click"/>
                </StackPanel>
                <TextBlock VerticalAlignment="Bottom" HorizontalAlignment="Center" Foreground="#FFBDBDBD" Margin="0,0,0,25">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0} {1}">
                            <Binding Source="{x:Static languages:Lang.login_window_powered_by}" />
                            <Binding Path="ServerName" Source="{x:Static properties:Settings.Default}" />
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</UserControl>
