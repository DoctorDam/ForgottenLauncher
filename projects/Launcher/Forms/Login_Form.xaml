<UserControl xmlns:Dropdowns="clr-namespace:Forgotten_Land_Launcher.Elements.Dropdowns"  x:Class="Forgotten_Land_Launcher.Forms.Login_Form"
             xmlns:Spinners="clr-namespace:Forgotten_Land_Launcher.Elements.Spinners" 
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:properties="clr-namespace:Forgotten_Land_Launcher.Properties"
             xmlns:languages="clr-namespace:Forgotten_Land_Launcher.Languages"
             mc:Ignorable="d" RenderOptions.BitmapScalingMode="HighQuality"
             FontFamily="Fira Sans Condensed">
    <Grid>
        <Border Background="#D8000000" CornerRadius="0,0,0,9" HorizontalAlignment="Left" Width="400">
            <Grid>
                <Image Source="/Forgotten Land Launcher;component/Assets/logos/launcher_server_logo.png" HorizontalAlignment="Center" VerticalAlignment="Top" Width="100" Margin="0,25,0,0"/>
                <StackPanel Width="350" HorizontalAlignment="Center" Margin="0,150,0,50">
                    <Grid>
                        <Grid HorizontalAlignment="Center">
                            <TextBox x:Name="textBoxUsername" Style="{DynamicResource loginTextBox}" Text="{x:Static languages:Lang.login_window_form_textbox_username}" GotFocus="TextBox_GotFocus"/>
                            <Image Source="/Forgotten Land Launcher;component/Assets/Icons/icon_people_1_a.png" Width="14" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>
                        <Image x:Name="warningIconUser" HorizontalAlignment="Right" VerticalAlignment="Center" Source="/Forgotten Land Launcher;component/Assets/icons/icon_warning_1_a.png" Width="18" Margin="0,0,20,0" Visibility="Hidden"/>
                    </Grid>
                    <Grid Margin="0,15,0,0">
                        <Grid HorizontalAlignment="Center">
                            <PasswordBox x:Name="textBoxPassword" Style="{DynamicResource loginPasswordBox}" Password="Password" GotFocus="TextBox_GotFocus"/>
                            <Image Source="/Forgotten Land Launcher;component/Assets/Icons/icon_lock_1_a.png" Width="14" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>
                        <Image x:Name="warningIconPass" HorizontalAlignment="Right" VerticalAlignment="Center" Source="/Forgotten Land Launcher;component/Assets/icons/icon_warning_1_a.png" Width="18" Margin="0,0,20,0" Visibility="Hidden"/>
                    </Grid>
                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,20,0,0" >
                        <CheckBox x:Name="checkboxLogin" Style="{DynamicResource CheckBoxStyle1}" Content="{x:Static languages:Lang.login_window_checkbox_remember}" FontSize="11" Foreground="#FF848484" VerticalContentAlignment="Center" HorizontalAlignment="Left" IsChecked="False">
                            <CheckBox.LayoutTransform>
                                <ScaleTransform ScaleX="1.2" ScaleY="1.2" />
                            </CheckBox.LayoutTransform>
                        </CheckBox>
                    </Grid>
                    <Button x:Name="btnLogin" Style="{DynamicResource loginSignInButton}" Content="{x:Static languages:Lang.login_window_button_sign_in}" Margin="0,20,0,0" Click="btnLogin_Click"/>
                    <Viewbox x:Name="loginSpinner" Height="40" Margin="0,15,0,0" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed">
                        <Spinners:Dotted_Spinner HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Viewbox>
                    <Grid Margin="0,25,0,0" Width="300">
                        <Border BorderThickness="0,0,0,1" BorderBrush="#FF3C3C3C" Width="30" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <TextBlock Text="{x:Static languages:Lang.login_window_form_divider_placeholder_1}" FontSize="14" Margin="0,-5,0,0" HorizontalAlignment="Center" Foreground="#FF848484" VerticalAlignment="Center"/>
                        <Border BorderThickness="0,0,0,1" BorderBrush="#FF3C3C3C" Width="30" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <StackPanel Margin="0,20,0,0" Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="RegisterButton" Style="{DynamicResource buttonStyle2}" Content="{x:Static languages:Lang.login_window_button_other_register}" Click="RegisterButton_Click"/>
                        <Button x:Name="RecoverButton" Style="{DynamicResource buttonStyle2}" Content="{x:Static languages:Lang.login_window_button_other_recover}" Margin="20,0,0,0" Click="RecoverButton_Click"/>
                    </StackPanel>
                    <Button x:Name="btnVisitHome" Style="{DynamicResource btnTosLink}" Content="{x:Static languages:Lang.login_window_button_other_visit_homepage}" Margin="0,25,0,10" Click="btnVisitHome_Click"/>
                    <Dropdowns:Language_Dropdown_Menu HorizontalAlignment="Center" />
                </StackPanel>
                <TextBlock VerticalAlignment="Bottom" HorizontalAlignment="Center" Foreground="#FFBDBDBD" Margin="0,0,0,25">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0} {1}">
                            <Binding Source="{x:Static languages:Lang.login_window_powered_by}" />
                            <Binding Path="ServerName" Source="{x:Static properties:Settings.Default}" />
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</UserControl>
