<UserControl x:Class="Forgotten_Land_Launcher.Pages.Shop" 
             xmlns:Spinners="clr-namespace:Forgotten_Land_Launcher.Elements.Spinners"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:languages="clr-namespace:Forgotten_Land_Launcher.Languages"
             mc:Ignorable="d" 
             Width="930" Height="625" Foreground="#FF999999">
    <Border CornerRadius="5" Background="#7F151515" BorderThickness="0.5" BorderBrush="#FF232323">
        <Grid>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="25,25,0,0" VerticalAlignment="Top">
                <Image Source="/Forgotten Land Launcher;component/Assets/icons/icon_cart_2_a.png" Width="25" Height="25" VerticalAlignment="Center"/>
                <TextBlock Text="{x:Static languages:Lang.page_shop_title}" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" Margin="10,0,0,0"/>
            </StackPanel>
            <Grid Margin="15,60,15,15">
                <StackPanel x:Name="spLoading" Orientation="Horizontal" Visibility="Visible" VerticalAlignment="Top" Margin="15,0,0,0">
                    <TextBlock Text="{x:Static languages:Lang.page_loading_message}" VerticalAlignment="Center"/>
                    <Viewbox Width="15" Margin="5,0,0,0">
                        <Spinners:Dotted_Spinner />
                    </Viewbox>
                </StackPanel>
                <StackPanel x:Name="spDisabled" Orientation="Horizontal" VerticalAlignment="Top" Margin="15,0,0,0">
                    <Image Source="/Forgotten Land Launcher;component/Assets/icons/icon_lock_2_a.png" Width="15" VerticalAlignment="Top"/>
                    <TextBlock x:Name="PageDisabledPlaceholder" Text="{x:Static languages:Lang.page_locked_message}" Foreground="#FFFFD096" FontSize="14" FontStyle="Italic" Margin="5,0,0,0"/>
                </StackPanel>
                <Border HorizontalAlignment="Left" VerticalAlignment="Center" Width="210" Height="548">
                    <ScrollViewer Style="{DynamicResource ScrollViewerOne}">
                        <StackPanel x:Name="spCategoryButtons" Orientation="Vertical"/>
                    </ScrollViewer>
                </Border>
                <ScrollViewer Style="{DynamicResource ScrollViewerOne}" HorizontalAlignment="Right" VerticalAlignment="Top" Height="548" Width="680">
                    <WrapPanel x:Name="wpShopList"/>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</UserControl>
