<UserControl x:Class="Forgotten_Land_Launcher.Pages.Article_Viewer"
             xmlns:Spinners="clr-namespace:Forgotten_Land_Launcher.Elements.Spinners"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:languages="clr-namespace:Forgotten_Land_Launcher.Languages"
             mc:Ignorable="d" Width="960" Height="625" Foreground="White">
    <Grid>
        <StackPanel Orientation="Vertical" HorizontalAlignment="Left" VerticalAlignment="Top">
            <StackPanel x:Name="spLoading" Orientation="Horizontal" Visibility="Visible">
                <TextBlock Text="{x:Static languages:Lang.page_loading_message}" VerticalAlignment="Center"/>
                <Viewbox Width="15" Margin="5,0,0,0">
                    <Spinners:Dotted_Spinner />
                </Viewbox>
            </StackPanel>
            <StackPanel x:Name="spDisabled" Orientation="Horizontal">
                <Image Source="/Forgotten Land Launcher;component/Assets/icons/icon_lock_2_a.png" Width="15" VerticalAlignment="Top"/>
                <TextBlock x:Name="PageDisabledPlaceholder" Text="{x:Static languages:Lang.page_locked_message}" Foreground="#FFFFD096" FontSize="14" FontStyle="Italic" Margin="5,0,0,0"/>
            </StackPanel>
        </StackPanel>
        <ScrollViewer x:Name="svArticle" Style="{DynamicResource ScrollViewerOne}" Visibility="Collapsed">
            <StackPanel Orientation="Vertical">
                <Grid Height="200" VerticalAlignment="Top">
                    <Border x:Name="border" CornerRadius="5" Padding="0" Height="200">
                        <Grid>
                            <Border Name="mask" Background="Black" CornerRadius="{Binding ElementName=border, Path=CornerRadius}"/>
                            <Grid>
                                <Grid.OpacityMask>
                                    <VisualBrush Visual="{Binding ElementName=mask}"/>
                                </Grid.OpacityMask>
                                <MediaElement x:Name="movieLoader" LoadedBehavior="Manual" MediaEnded="movieLoader_MediaEnded" Height="200" IsMuted="True" Stretch="UniformToFill"/>
                                <Border CornerRadius="5">
                                    <Border.Background>
                                        <ImageBrush x:Name="bannerHolder" Stretch="UniformToFill"/>
                                    </Border.Background>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                    <Border CornerRadius="5" Background="#59000000"/>
                    <TextBlock x:Name="titleHolder" Text="Title holder.." VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="28" FontFamily="Semplicita Pro SemiBold" FontWeight="Bold" MaxWidth="800" TextTrimming="CharacterEllipsis" TextWrapping="Wrap" TextAlignment="Center" MaxHeight="120"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,15">
                        <TextBlock FontFamily="Semplicita Pro Medium" MaxWidth="600" TextTrimming="CharacterEllipsis" TextAlignment="Center" FontSize="16" Foreground="#FFEBDEC2" VerticalAlignment="Center">
                            <Run x:Name="dateHolder" Text="On date"/>
                            <Run Text="by"/>
                            <Run x:Name="authorHolder" Text="Author" Foreground="#FFF8B700"/>
                            <Run Text="-"/>
                        </TextBlock>
                        <Button x:Name="ButtonRedirect" Content="Read more.." Style="{DynamicResource btnTosLink}" FontFamily="Semplicita Pro Medium" FontSize="16" VerticalAlignment="Center" Click="ButtonRedirect_Click"/>
                    </StackPanel>
                </Grid>
                <Grid Margin="0,25,0,0">
                    <TextBlock x:Name="contentHolder" Text="" TextWrapping="Wrap" Foreground="#FFEBDEC2" FontFamily="Semplicita Pro SemiBold" FontSize="16"/>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
