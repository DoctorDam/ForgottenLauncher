<UserControl x:Class="Forgotten_Land_Launcher.Pages.Online_Players"
             xmlns:Spinners="clr-namespace:Forgotten_Land_Launcher.Elements.Spinners"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:languages="clr-namespace:Forgotten_Land_Launcher.Languages"
             mc:Ignorable="d" 
             Width="930" Height="625" Foreground="#FF999999">
    <Border CornerRadius="10">
        <Grid>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="25,25,0,0" VerticalAlignment="Top">
                <!--<Image Source="/Forgotten Land Launcher;component/Assets/icons/icon_cart_2_a.png" Width="25" Height="25" VerticalAlignment="Center"/>-->
                <TextBlock Text="{x:Static languages:Lang.page_online_players_title}" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock x:Name="onlineStatsHolder" Margin="0,25,0,0" FontSize="16" VerticalAlignment="Top" HorizontalAlignment="Center">
                    <Run x:Name="playersCountHolder" Text="x players"/>
                    <Run x:Name="displayCountHolder" Text="(y displayed)" Foreground="#FFBFBFBF"/>
            </TextBlock>
            <ComboBox x:Name="RealmsDropdown" Style="{DynamicResource ComboBoxStyle1}" Margin="0,10,35,0" Padding="7,7,7,7" Width="250" HorizontalAlignment="Right" VerticalAlignment="Top" SelectionChanged="RealmsDropdown_SelectionChanged" Foreground="#FFC7C7C7" FontWeight="Bold"/>
            <Grid HorizontalAlignment="Left" VerticalAlignment="Top" Margin="20,50,0,0">
                <StackPanel x:Name="spLoading" Orientation="Horizontal" Visibility="Visible">
                    <TextBlock Text="{x:Static languages:Lang.page_loading_message}" VerticalAlignment="Center"/>
                    <Viewbox Width="15" Margin="5,0,0,0">
                        <Spinners:Dotted_Spinner />
                    </Viewbox>
                </StackPanel>
                <StackPanel x:Name="spDisabled" Orientation="Horizontal">
                    <Image Source="/Forgotten Land Launcher;component/Assets/icons/icon_lock_2_a.png" Width="15" VerticalAlignment="Top"/>
                    <TextBlock x:Name="PageDisabledPlaceholder" Text="{x:Static languages:Lang.page_locked_message}" Foreground="#FFFFD096" FontSize="14" FontStyle="Italic" Margin="5,0,0,0"/>
                </StackPanel>
            </Grid>
            <ScrollViewer Style="{DynamicResource ScrollViewerOne}" Margin="0,60,0,0" Padding="4,0,4,4">
                <StackPanel x:Name="spOnlinePlayers" Orientation="Vertical" Margin="15,0,15,0"/>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
