<UserControl x:Class="Forgotten_Land_Launcher.Pages.Characters_Market"
             xmlns:Spinners="clr-namespace:Forgotten_Land_Launcher.Elements.Spinners"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:languages="clr-namespace:Forgotten_Land_Launcher.Languages"
             mc:Ignorable="d" 
             Width="960" Height="625" Foreground="#FF999999">
    <Grid>
        <StackPanel Orientation="Vertical" VerticalAlignment="Top" HorizontalAlignment="Left" Visibility="Visible">
            <StackPanel x:Name="spPageTitle" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top">
                <Image Source="/Forgotten Land Launcher;component/Assets/icons/icon_market_1.png" Width="25" VerticalAlignment="Center" Opacity="0.75"/>
                <TextBlock Text="{x:Static languages:Lang.page_characters_market_title}" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" Margin="10,0,0,0"/>
                <ComboBox Style="{DynamicResource ComboBoxStyle1}" x:Name="RealmsDropdown" Padding="7,7,7,7" Width="200" Margin="50,0,0,0" SelectedIndex="0" VerticalAlignment="Center" Foreground="#FFC7C7C7" FontWeight="Bold" IsEnabled="False" SelectionChanged="RealmsDropdown_SelectionChanged"/>
                <TextBox x:Name="searchHolder" Text="{x:Static languages:Lang.page_characters_market_textbox_player_search}" Style="{DynamicResource inputTextBox}" Background="#FF1D1D1D" FontSize="14" BorderBrush="#FF272727" Padding="25,5,25,5" Foreground="#FF999999" SelectionBrush="#FF444444" SelectionTextBrush="#FF565656" TextAlignment="Center" Margin="15,0,0,0" VerticalAlignment="Center" Width="140" GotFocus="searchHolder_GotFocus" LostFocus="searchHolder_LostFocus"/>
                <Button x:Name="searchButton" Style="{DynamicResource buttonStyle4}" Content="{x:Static languages:Lang.page_characters_market_button_search}" Height="28" Width="80" Background="#FF287B86" Margin="15,0,0,0" VerticalAlignment="Center" Click="searchButton_Click"/>
                <Border BorderThickness="0.5" Margin="10,0,0,0" BorderBrush="#FF272727" VerticalAlignment="Center" Height="20"/>
                <Button x:Name="sellButton" Style="{DynamicResource buttonStyle4}" Content="{x:Static languages:Lang.page_characters_market_button_sell}" Height="28" Width="80" Background="#FF2F8628" Margin="10,0,0,0" VerticalAlignment="Center" Click="sellButton_Click"/>
                <Border BorderThickness="0.5" Margin="10,0,0,0" BorderBrush="#FF272727" VerticalAlignment="Center" Height="20"/>
                <Button x:Name="mySalesButton" Style="{DynamicResource buttonStyle4}" Content="{x:Static languages:Lang.page_characters_market_button_my_sales}" Height="28" Width="110" Background="#FF866428" Margin="10,0,0,0" VerticalAlignment="Center" Click="mySalesButton_Click"/>
            </StackPanel>
            <StackPanel x:Name="spLoading" Orientation="Horizontal" Visibility="Collapsed" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,15,0,0">
                <TextBlock Text="{x:Static languages:Lang.page_loading_message}" VerticalAlignment="Center"/>
                <Viewbox Width="15" Margin="5,0,0,0">
                    <Spinners:Dotted_Spinner />
                </Viewbox>
            </StackPanel>
            <StackPanel x:Name="spDisabled" Orientation="Horizontal" Visibility="Collapsed" Margin="0,15,0,0">
                <Image Source="/Forgotten Land Launcher;component/Assets/icons/icon_lock_2_a.png" Width="15" VerticalAlignment="Top"/>
                <TextBlock x:Name="PageDisabledPlaceholder" Text="{x:Static languages:Lang.page_locked_message}" Foreground="#FFFFD096" FontSize="14" FontStyle="Italic" Margin="5,0,0,0"/>
            </StackPanel>
        </StackPanel>
        <ScrollViewer Style="{DynamicResource ScrollViewerOne}" Margin="0,50,0,0">
            <Grid>
                <WrapPanel x:Name="wpCharacters" Orientation="Horizontal"/>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
