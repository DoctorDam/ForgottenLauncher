<UserControl x:Class="Forgotten_Land_Launcher.Pages.Ladderboard"
             xmlns:Spinners="clr-namespace:Forgotten_Land_Launcher.Elements.Spinners"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:languages="clr-namespace:Forgotten_Land_Launcher.Languages"
             mc:Ignorable="d" 
             Width="930" Height="625" Foreground="#FF999999">
    <Border CornerRadius="10" Background="#26000000" BorderThickness="1,1,1,1" BorderBrush="#FF252525">
        <Grid>
            <TextBlock Text="{x:Static languages:Lang.page_ladderboards_title}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,15,0,0" VerticalAlignment="Top"/>
            <Grid HorizontalAlignment="Left" VerticalAlignment="Top" Margin="20,50,0,0">
                <StackPanel x:Name="spLoading" Orientation="Horizontal" Visibility="Visible">
                    <TextBlock Text="{x:Static languages:Lang.page_loading_message}" VerticalAlignment="Center"/>
                    <Viewbox Width="15" Margin="5,0,0,0">
                        <Spinners:Dotted_Spinner />
                    </Viewbox>
                </StackPanel>
                <StackPanel x:Name="spDisabled" Orientation="Horizontal">
                    <Image Source="/Forgotten Land Launcher;component/Assets/icons/icon_lock_2_a.png" Width="15" VerticalAlignment="Top"/>
                    <TextBlock x:Name="PageDisabledPlaceholder" Text="{x:Static languages:Lang.page_locked_message}" Foreground="#FFFFD096" FontSize="14" FontStyle="Italic" Margin="5,0,0,0"/>
                </StackPanel>
            </Grid>
            <Grid x:Name="tableHeader" Background="#FF1D1D1D" VerticalAlignment="Top" Margin="20,50,0,0" Width="873" HorizontalAlignment="Left">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="25"/>
                </Grid.RowDefinitions>
                <!--POSITION-->
                <Border Grid.Column="0" Grid.Row="0" BorderThickness="0,0,1,0" BorderBrush="#FF444444">
                    <TextBlock Text="#" FontWeight="Bold" VerticalAlignment="Center" Margin="5,0,0,0"/>
                </Border>
                <!--NAME-->
                <Border Grid.Column="1" Grid.Row="0" BorderThickness="0,0,1,0" BorderBrush="#FF444444">
                    <TextBlock Text="{x:Static languages:Lang.page_ladderboards_column_name}" Margin="10,0,0,0" FontWeight="Bold" VerticalAlignment="Center"/>
                </Border>
                <!--RACE-->
                <Border Grid.Column="2" Grid.Row="0" BorderThickness="0,0,1,0" BorderBrush="#FF444444">
                    <TextBlock Text="{x:Static languages:Lang.page_ladderboards_column_race}" HorizontalAlignment="Center" FontWeight="Bold" VerticalAlignment="Center"/>
                </Border>
                <!--CLASS-->
                <Border Grid.Column="3" Grid.Row="0" BorderThickness="0,0,1,0" BorderBrush="#FF444444">
                    <TextBlock Text="{x:Static languages:Lang.page_ladderboards_column_class}" HorizontalAlignment="Center" FontWeight="Bold" VerticalAlignment="Center"/>
                </Border>
                <!--TODAY KILLS-->
                <Border Grid.Column="4" Grid.Row="0" BorderThickness="0,0,1,0" BorderBrush="#FF444444">
                    <TextBlock Text="{x:Static languages:Lang.page_ladderboards_column_today_kills}" HorizontalAlignment="Center" FontWeight="Bold" VerticalAlignment="Center"/>
                </Border>
                <!--YESTERDAY KILLS-->
                <Border Grid.Column="5" Grid.Row="0" BorderThickness="0,0,1,0" BorderBrush="#FF444444">
                    <TextBlock Text="{x:Static languages:Lang.page_ladderboards_column_yesterday_kills}" HorizontalAlignment="Center" FontWeight="Bold" VerticalAlignment="Center"/>
                </Border>
                <!--TOTAL KILLS-->
                <Border Grid.Column="6" Grid.Row="0" BorderThickness="0,0,1,0" BorderBrush="#FF444444">
                    <TextBlock Text="{x:Static languages:Lang.page_ladderboards_column_total_kills}" HorizontalAlignment="Center" FontWeight="Bold" VerticalAlignment="Center"/>
                </Border>
                <!--REALM-->
                <Border Grid.Column="7" Grid.Row="0" BorderThickness="0,0,1,0" BorderBrush="#FF444444">
                    <TextBlock Text="{x:Static languages:Lang.page_ladderboards_column_realm_name}" HorizontalAlignment="Center" FontWeight="Bold" VerticalAlignment="Center"/>
                </Border>
            </Grid>
            <ScrollViewer Style="{DynamicResource ScrollViewerOne}" Margin="0,75,0,0" Padding="4,0,4,4">
                <StackPanel x:Name="spLadderboard" Orientation="Vertical" Margin="15,0,15,0"/>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
