<UserControl x:Class="Forgotten_Land_Launcher.Pages.Private_Message_New"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:languages="clr-namespace:Forgotten_Land_Launcher.Languages"
             mc:Ignorable="d" RenderOptions.BitmapScalingMode="HighQuality"
             Width="935" Height="625" Foreground="#FF999999">
    <Border CornerRadius="10" Background="#26000000" BorderThickness="1,1,1,1" BorderBrush="#FF252525">
        <StackPanel Orientation="Vertical">
            <Grid>
                <TextBlock Text="{x:Static languages:Lang.page_create_message_title}" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" Margin="0,15,0,0"/>
            </Grid>
            <Grid Height="550" Margin="25,25,25,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Top">
                    <Image Source="/Forgotten Land Launcher;component/Assets/icons/icon_profile_2_a.png" Width="20" VerticalAlignment="Center"/>
                    <TextBox x:Name="receiverHolder" Text="{x:Static languages:Lang.page_create_message_textbox_nickname}" Margin="10,0,0,0" Style="{DynamicResource inputTextBox2}" Width="150" 
                             FontFamily="Fira Sans Condensed" Padding="7,7,10,7" Background="#FF1F1A0B" Foreground="#FF8C8C8C" 
                             BorderBrush="#FF2F2713" VerticalContentAlignment="Center" SelectionBrush="#FF75652C" GotFocus="receiverHolder_GotFocus"/>
                    <Image Source="/Forgotten Land Launcher;component/Assets/icons/icon_email_2_a.png" Width="20" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    <TextBox x:Name="titleHolder" Text="{x:Static languages:Lang.page_create_message_textbox_message_subject}" Margin="10,0,0,0" Style="{DynamicResource inputTextBox2}" Width="250" 
                             FontFamily="Fira Sans Condensed" Padding="7,7,10,7" Background="#FF232323" Foreground="#FF8C8C8C" 
                             BorderBrush="#FF313131" VerticalContentAlignment="Center" SelectionBrush="#FF6F6F6F" GotFocus="receiverHolder_GotFocus" MaxLength="50"/>
                </StackPanel>
                <ScrollViewer Margin="0,40,0,0" Height="420" Style="{DynamicResource ScrollViewerOne}" VerticalAlignment="Top" HorizontalAlignment="Left" Padding="0,4,4,4">
                    <TextBox x:Name="messageHolder" Style="{DynamicResource inputTextBox2}" AcceptsReturn="True" AcceptsTab="True" 
                         HorizontalAlignment="Left" Foreground="#FF8C8C8C" VerticalAlignment="Top" TextWrapping="Wrap"
                         Background="#3F000000" Width="850" FontSize="14" BorderBrush="#3F2F2F2F" SelectionBrush="#FF75652C"
                         FontFamily="Fira Sans Condensed" Padding="7,7,10,7" MinHeight="420" MaxLength="2500" TextChanged="messageHolder_TextChanged">
                    </TextBox>
                </ScrollViewer>
                <TextBlock VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="5,0,0,60" FontWeight="Bold">
                    <Run Text="{x:Static languages:Lang.page_create_message_text_characters}"/>
                    <Run x:Name="charCount" Text="0"/>
                    <Run Text="/"/>
                    <Run Text="2500"/>
                </TextBlock>
                <StackPanel Margin="0,0,0,30" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom">
                    <Button x:Name="btnSend" Style="{DynamicResource btnNewMessage}" Content="{x:Static languages:Lang.page_create_message_button_send}" 
                        Padding="15,10,15,10" 
                        Background="#FF0B8E00" BorderBrush="{x:Null}" BorderThickness="0,0,0,0" Foreground="#FFE8E8E8" 
                        FontWeight="Bold" Cursor="Hand" Click="btnSend_Click"/>
                    <Button x:Name="btnCancel" Style="{DynamicResource btnNewMessage}" Content="{x:Static languages:Lang.page_create_message_button_back}" 
                        Padding="15,10,15,10" 
                        Background="#FF8E3400" BorderBrush="{x:Null}" BorderThickness="0,0,0,0" Foreground="#FFE8E8E8" 
                        FontWeight="Bold" Cursor="Hand" Margin="15,0,0,0" Click="btnCancel_Click"/>
                </StackPanel>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
