<UserControl x:Class="Forgotten_Land_Launcher.Dialogs.Inventory_Reward_Dialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:languages="clr-namespace:Forgotten_Land_Launcher.Languages"
             xmlns:Spinners="clr-namespace:Forgotten_Land_Launcher.Elements.Spinners"
             xmlns:gif="http://wpfanimatedgif.codeplex.com"
             mc:Ignorable="d" RenderOptions.BitmapScalingMode="HighQuality"
             Loaded="UserControl_Loaded">
    <Grid>
        <Border CornerRadius="7" Background="#F20E0E0E">
            <Border CornerRadius="7" HorizontalAlignment="Center" VerticalAlignment="Center" Background="#FF191919" MaxWidth="500" MinWidth="300">
                <StackPanel Margin="20,20,20,20">
                    <StackPanel x:Name="spItemDialog">
                        <TextBlock x:Name="dialogTitle" Text="Item title" Foreground="#FFCACACA" HorizontalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                        <TextBlock Foreground="#FF7F7F7F" HorizontalAlignment="Center" Margin="0,5,0,0">
                            <Run Text="{x:Static languages:Lang.dialog_inventory_item_acquired_on}"/>
                            <Run x:Name="acquiredHolder" Text="date"/>
                        </TextBlock>
                        <Border CornerRadius="7" Height="200" Margin="0,10,0,0" Width="300">
                            <Border.Background>
                                <ImageBrush x:Name="pictureHolder" Stretch="UniformToFill"/>
                            </Border.Background>
                        </Border>
                        <TextBlock x:Name="dialogDescription" Text="................" Margin="0,10,0,0" Foreground="#FFB5B5B5" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                        <StackPanel x:Name="spPlayerSelection" Margin="0,10,0,0">
                            <StackPanel x:Name="spPlayerSelectionLoading">
                                <TextBlock Text="{x:Static languages:Lang.dialog_inventory_item_text_loading_characters}" Margin="0,10,0,0" Foreground="#FF7F7F7F" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                                <Viewbox Width="30">
                                    <Spinners:Dotted_Spinner Margin="0,30,0,0" />
                                </Viewbox>
                            </StackPanel>
                            <StackPanel x:Name="spPlayerSelectionLoaded">
                                <TextBlock Text="{x:Static languages:Lang.dialog_inventory_item_text_require_character}" Foreground="#FF7F7F7F" HorizontalAlignment="Center"/>
                                <ComboBox Style="{DynamicResource ComboBoxStyle1}" x:Name="cbCharacters" Margin="0,10,0,0" Padding="7,7,7,7" Width="350" SelectionChanged="cbCharacters_SelectionChanged"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel x:Name="spInput" Width="350" Margin="0,10,0,0">
                            <TextBlock Text="{x:Static languages:Lang.dialog_inventory_item_text_require_input}" Foreground="#FF7F7F7F" HorizontalAlignment="Center"/>
                            <TextBox x:Name="inputHolder" Style="{DynamicResource inputTextBox}" Background="#FF1D1D1D" FontSize="14" BorderBrush="#FF3E3E3E" Margin="0,10,0,0" Padding="5,5,5,5" Foreground="#FFB5B5B5" SelectionBrush="#FF444444" SelectionTextBrush="#FF565656" TextAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                            <Button x:Name="okButton" Style="{DynamicResource buttonStyle4}" Content="{x:Static languages:Lang.general_button_use}" Height="25" Width="80" Background="#FF498628" Click="okButton_Click" IsEnabled="False"/>
                            <Button x:Name="cancelButton" Style="{DynamicResource buttonStyle5}" Content="{x:Static languages:Lang.general_button_cancel}" Height="25" Width="80" Margin="15,0,0,0" Background="#FF862828" Click="cancelButton_Click"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel x:Name="spWaitDialog" Margin="20,20,20,0" Visibility="Collapsed">
                        <TextBlock x:Name="waitTitle" Text="{x:Static languages:Lang.general_dialog_text_processing}" Foreground="#FFCACACA" HorizontalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                        <TextBlock x:Name="waitDescription" Text="{x:Static languages:Lang.dialog_inventory_item_text_wait}" Margin="0,10,0,0" Foreground="#FFB5B5B5" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                        <Viewbox x:Name="vbSpinner" Width="30">
                            <Spinners:Dotted_Spinner Margin="0,30,0,0" />
                        </Viewbox>
                        <Viewbox x:Name="vbCheckmark" Width="45" Visibility="Collapsed" Margin="0,15,0,0">
                            <Image x:Name="checkMarkGif" gif:ImageBehavior.AutoStart="False" 
                                   gif:ImageBehavior.RepeatBehavior="1x" 
                                   gif:ImageBehavior.AnimatedSource="/Forgotten Land Launcher;component/Assets/gifs/checkmark_2.gif"  />
                        </Viewbox>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
