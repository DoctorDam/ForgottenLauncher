<Border x:Class="Forgotten_Land_Launcher.Dialogs.Wait_Dialog"
        xmlns:Spinners="clr-namespace:Forgotten_Land_Launcher.Elements.Spinners"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d" RenderOptions.BitmapScalingMode="HighQuality"
        Background="#CC0E0E0E" CornerRadius="7" Loaded="Border_Loaded">
    <Grid>
        <Border CornerRadius="7" Background="#CC0E0E0E">
            <Border CornerRadius="7" HorizontalAlignment="Center" VerticalAlignment="Center" Background="#FF191919" MaxWidth="500" MinWidth="300">
                <StackPanel Margin="20,20,20,20">
                    <TextBlock x:Name="waitingTitle" Text="Waiting title" Foreground="#FFCACACA" HorizontalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                    <TextBlock x:Name="waitingText" Text=".............." Margin="0,10,0,0" Foreground="#FFB5B5B5" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                    <Viewbox Width="30">
                        <Spinners:Dotted_Spinner Margin="0,30,0,0" />
                    </Viewbox>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Border>
