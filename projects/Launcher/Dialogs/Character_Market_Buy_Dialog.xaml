<UserControl x:Class="Forgotten_Land_Launcher.Dialogs.Character_Market_Buy_Dialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:languages="clr-namespace:Forgotten_Land_Launcher.Languages"
             xmlns:gif="http://wpfanimatedgif.codeplex.com"
             xmlns:Spinners="clr-namespace:Forgotten_Land_Launcher.Elements.Spinners"
             mc:Ignorable="d" RenderOptions.BitmapScalingMode="HighQuality"
             Loaded="UserControl_Loaded" Foreground="#FFCACACA">
    <Grid>
        <Border CornerRadius="7" Background="#F20E0E0E">
            <Border CornerRadius="7" HorizontalAlignment="Center" VerticalAlignment="Center" Background="#FF191919" MaxWidth="500" MinWidth="300" BorderThickness="1,1,1,1" BorderBrush="#FF2F2F2F">
                <Border CornerRadius="7" Padding="25,0,25,0">
                    <Border.Background>
                        <ImageBrush x:Name="BackgroundHolder" Stretch="UniformToFill" Opacity="0.05"/>
                    </Border.Background>
                    <StackPanel>
                        <StackPanel x:Name="spFirstDialog" Margin="10,15,10,15">
                            <TextBlock Foreground="#FFCACACA" HorizontalAlignment="Center" FontSize="16">
                            <!--<Run Text="Market Character" Foreground="#FFA4A4A4"/>-->
                            <Run x:Name="CharNameHolder" FontWeight="Bold" Text="Name"/>
                            </TextBlock>
                            <Grid HorizontalAlignment="Center" Margin="0,10,0,0">
                                <Border CornerRadius="10" Width="45" Height="45" BorderThickness="1,1,1,1" BorderBrush="#FF9E9E9E">
                                    <Border.Background>
                                        <ImageBrush x:Name="RaceAvatarHolder" Stretch="UniformToFill"/>
                                    </Border.Background>
                                </Border>
                                <Border CornerRadius="5" Width="18" Height="18" BorderThickness="1,1,1,1" BorderBrush="#FF272727" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,-1,-5,-5">
                                    <Border.Background>
                                        <ImageBrush x:Name="ClassAvatarHolder"/>
                                    </Border.Background>
                                </Border>
                            </Grid>
                            <TextBlock Foreground="#FFCACACA" HorizontalAlignment="Center" FontSize="12" Margin="0,10,0,0">
                                <Run Foreground="#FFA4A4A4" Text="Level"/>
                                <Run x:Name="CharLevelHolder" Foreground="White" Text="0,"/>
                                <Run x:Name="CharRaceHolder" Foreground="#FFA4A4A4" Text="Race,"/>
                                <Run x:Name="CharClassHolder" Text="Class" Foreground="#FF008E16"/>
                            </TextBlock>
                            <Border BorderThickness="0.5" BorderBrush="#FF232323" Margin="0,10,0,0"/>
                            <TextBlock Margin="0,10,0,0" Foreground="#FFB5B5B5" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center">
                                <Run Text="{x:Static languages:Lang.page_characters_market_dialog_text_gold_held}"/>
                                <Run x:Name="CharGoldHolder" Text="0" Foreground="#FFDBA113"/>
                            <Image Source="/Forgotten Land Launcher;component/Assets/icons/icon_gold_coin_3.png" Width="9"/>
                            </TextBlock>
                            <!--<Border BorderThickness="0.5" BorderBrush="#FF232323" Margin="0,10,0,0"/>-->
                            <TextBlock Margin="0,10,0,0" Foreground="#FFB5B5B5" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center">
                                <Run x:Name="CharProfessionsCount" Text="0" Foreground="#FF00EDFF"/>
                            <Image Source="/Forgotten Land Launcher;component/Assets/icons/icon_needle_1_a.png" Width="9"/>
                                <Run Text="{x:Static languages:Lang.page_characters_market_dialog_text_professions}"/>
                            </TextBlock>
                            <StackPanel x:Name="spProfessions" Orientation="Vertical" Margin="0,10,0,0" MinWidth="250" MaxWidth="250" Visibility="Visible"/>
                            <!--<Border BorderThickness="0.5" BorderBrush="#FF232323" Margin="0,10,0,0"/>-->
                            <TextBlock Margin="0,10,0,0" Foreground="#FFCEA83D" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center">
                                <Run Text="{x:Static languages:Lang.page_characters_market_dialog_text_pvp_score}"/>
                                <Run x:Name="CharKillsHolder" Text="0" Foreground="Red"/>
                            <Image Source="/Forgotten Land Launcher;component/Assets/icons/icon_swords_1_a.png" Width="9"/>
                            </TextBlock>
                            <!--<Border BorderThickness="0.5" BorderBrush="#FF232323" Margin="0,10,0,0"/>-->
                            <Button x:Name="armoryButton" Style="{DynamicResource buttonStyle4b}" Content="{x:Static languages:Lang.page_characters_market_dialog_button_armory}" Height="20" Margin="0,10,0,0" FontSize="10" HorizontalAlignment="Center" Padding="15,1,15,1" Click="armoryButton_Click"/>
                            <StackPanel x:Name="spCost" Orientation="Vertical" Margin="0,10,0,0" HorizontalAlignment="Center">
                                <TextBlock x:Name="priceTypeHolder" Text="{x:Static languages:Lang.page_characters_market_dialog_text_sale_price}" HorizontalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                                <!--<Border BorderThickness="0,0,0,1" BorderBrush="#FF272727" Margin="0,5,0,0"/>-->
                                <StackPanel Orientation="Horizontal" Margin="10,10,0,0" HorizontalAlignment="Center">
                                    <StackPanel x:Name="spDPCost" Orientation="Horizontal">
                                        <TextBlock x:Name="PriceHolder" Text="0" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="Bold"/>
                                        <Image Source="/Forgotten Land Launcher;component/Assets/icons/icon_gold_coin_1_a.png" Width="12" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel x:Name="spBiddingPrice" Orientation="Vertical" Margin="0,10,0,0">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="{x:Static languages:Lang.page_characters_market_dialog_text_buy_bid_amount}" Foreground="#FFB5B5B5"/>
                                        <TextBlock x:Name="priceErrorHolder" Foreground="#FF941B1B" Margin="3,0,0,0" MaxWidth="180" TextTrimming="CharacterEllipsis" Visibility="Collapsed"/>
                                    </StackPanel>
                                    <Grid HorizontalAlignment="Center" Margin="0,5,0,0">
                                        <TextBox x:Name="biddingPriceHolder" Style="{DynamicResource inputTextBox}" Background="#FF1D1D1D" FontSize="14" BorderBrush="#FF272727" Padding="5,5,25,5" Foreground="#FFB5B5B5" SelectionBrush="#FF444444" SelectionTextBrush="#FF565656" TextAlignment="Right" Width="150" Text="0" MaxLines="1" GotFocus="biddingPriceHolder_GotFocus" PreviewKeyUp="biddingPriceHolder_PreviewKeyUp" PreviewTextInput="biddingPriceHolder_PreviewTextInput"/>
                                        <Image Source="/Forgotten Land Launcher;component/Assets/icons/icon_gold_coin_1_a.png" Width="12" HorizontalAlignment="Right" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                                <Button x:Name="PurchaseButton" Style="{DynamicResource buttonStyle4}" Content="{x:Static languages:Lang.general_button_purchase}" Height="25" Click="PurchaseButton_Click" Padding="15,1,15,1" MaxWidth="180" Background="#FF498628"/>
                                <Button x:Name="cancelButton" Style="{DynamicResource buttonStyle5}" Content="{x:Static languages:Lang.general_button_cancel}" Height="25" Width="80" Margin="15,0,0,0" Background="#FF862828" Click="cancelButton_Click"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel x:Name="spWaitDialog" Margin="20,20,20,20" Visibility="Collapsed">
                            <TextBlock x:Name="waitTitle" Text="Processing" Foreground="#FFCACACA" HorizontalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                            <TextBlock x:Name="waitDescription" Text="Please wait while we process your request.." Margin="0,10,0,0" Foreground="#FFB5B5B5" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                            <Viewbox x:Name="vbSpinner" Width="30">
                                <Spinners:Dotted_Spinner Margin="0,30,0,0" />
                            </Viewbox>
                            <Viewbox x:Name="vbCheckmark" Width="45" Visibility="Collapsed" Margin="0,15,0,0">
                                <Image x:Name="checkMarkGif" gif:ImageBehavior.AutoStart="False" 
                                gif:ImageBehavior.RepeatBehavior="1x" 
                                gif:ImageBehavior.AnimatedSource="/Forgotten Land Launcher;component/Assets/gifs/checkmark_2.gif"  />
                            </Viewbox>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Border>
        </Border>
    </Grid>
</UserControl>
