<Border x:Class="Forgotten_Land_Launcher.Dialogs.Character_Market_Notifications_Dialog"
        xmlns:Spinners="clr-namespace:Forgotten_Land_Launcher.Elements.Spinners"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:languages="clr-namespace:Forgotten_Land_Launcher.Languages"
        mc:Ignorable="d" RenderOptions.BitmapScalingMode="HighQuality"
        Background="#CC0E0E0E" CornerRadius="7" Loaded="Border_Loaded">
    <Grid>
        <Border CornerRadius="7" Background="#CC0E0E0E">
            <Border CornerRadius="7" HorizontalAlignment="Center" VerticalAlignment="Center" Background="#FF191919" MaxWidth="500" MinWidth="300">
                <StackPanel Margin="20,20,20,20">
                    <TextBlock Text="{x:Static languages:Lang.page_characters_market_dialog_title_congratulations}" Foreground="#FFCACACA" HorizontalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                    <Image Margin="0,10,0,0" Source="/Forgotten Land Launcher;component/Assets/icons/icon_party_popper.png" Width="40" Height="40"/>
                    <TextBlock Text="{x:Static languages:Lang.page_characters_market_dialog_subtitle_won_auction}" Margin="0,10,0,0" Foreground="#FFB5B5B5" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                    <ScrollViewer Style="{DynamicResource ScrollViewerOne}" Margin="0,10,0,0" MaxHeight="160">
                        <StackPanel x:Name="spCharacters"/>
                    </ScrollViewer>
                    <Button x:Name="okButton" Style="{DynamicResource buttonStyle4}" Content="{x:Static languages:Lang.general_button_ok}" Height="25" Width="80" Background="#FF498628" Margin="0,20,0,0" Click="okButton_Click"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Border>
