<Button x:Class="Forgotten_Land_Launcher.Elements.Buttons.GameButtonCancelUpdate"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:languages="clr-namespace:Forgotten_Land_Launcher.Languages"
        mc:Ignorable="d" Style="{DynamicResource btnCancelGameUpdate}"
        BorderThickness="0,0,0,0" Padding="15,15,15,15"
        Background="#FF713434" BorderBrush="{x:Null}"
        Foreground="#FFCACACA" FontWeight="Bold" FontSize="16"
        Width="223">
    <StackPanel Orientation="Horizontal">
        <TextBlock Text="{x:Static languages:Lang.game_button_cancel_update}"/>
    </StackPanel>
</Button>
