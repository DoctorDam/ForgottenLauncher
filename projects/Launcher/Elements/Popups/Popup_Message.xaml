<UserControl x:Class="Forgotten_Land_Launcher.Elements.Popups.Popup_Message"
             x:Name="myControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Forgotten_Land_Launcher.Elements.Popups"
             mc:Ignorable="d" Width="400" Height="100" Loaded="myControl_Loaded">
    <Border CornerRadius="10" BorderBrush="#72313131" BorderThickness="1,1,1,1">
        <Border.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="#BFAFAFAF" Offset="1"/>
                <GradientStop Color="#BFC7C7C7" Offset="0"/>
            </LinearGradientBrush>
        </Border.Background>
        <Grid>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Width="358">
                <Image Source="/Forgotten Land Launcher;component/Assets/icons/icon_warning_1_a.png" Width="30" VerticalAlignment="Center" Opacity="0.75"/>
                <StackPanel>
                    <TextBlock Text="{Binding PopupTitle, ElementName=myControl, FallbackValue='Title', TargetNullValue='Title'}" Margin="10,0,0,0" FontWeight="Bold" Foreground="#FF3C3C3C" TextTrimming="CharacterEllipsis" Width="300" HorizontalAlignment="Left"/>
                    <TextBlock Text="{Binding PopupMessage, ElementName=myControl, FallbackValue='Message', TargetNullValue='Message'}" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" Width="310" Margin="10,5,0,0" Foreground="#FF4C4C4C" HorizontalAlignment="Left" MaxHeight="50"/>
                </StackPanel>
            </StackPanel>
            <Button x:Name="btnDispose" Style="{DynamicResource popupXButton}" Content="X" HorizontalAlignment="Right" VerticalAlignment="Top" Background="{x:Null}" BorderBrush="{x:Null}" BorderThickness="0,0,0,0" Foreground="#FF4C4C4C" Margin="0,5,10,0" FontFamily="Microsoft Sans Serif" FontWeight="Bold" Click="btnDispose_Click" FontSize="12"/>
        </Grid>
    </Border>
</UserControl>
