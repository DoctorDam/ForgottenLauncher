<UserControl x:Class="Forgotten_Land_Launcher.Elements.Popups.Game_More_Options"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:languages="clr-namespace:Forgotten_Land_Launcher.Languages"
             mc:Ignorable="d"
             Width="270" Loaded="UserControl_Loaded">
    <Border CornerRadius="5,5,5,5" BorderThickness="1,1,1,1" BorderBrush="#FF3A3A3A" Background="#FF222222">
        <Grid>
            <StackPanel x:Name="spMainMenu" Visibility="Visible">
                <StackPanel VerticalAlignment="Top">
                    <TextBlock Text="{x:Static languages:Lang.game_popup_more_options_title}" HorizontalAlignment="Left" VerticalAlignment="Top" Foreground="#FFDEDEDE" FontWeight="Bold" Margin="15,15,0,0" FontSize="13"/>
                    <Border BorderBrush="#FF4A4A4A" BorderThickness="0,0,0,1" VerticalAlignment="Top" Height="1" Margin="10,10,15,0"/>
                </StackPanel>
                <ScrollViewer Style="{DynamicResource ScrollViewerOne}"  Margin="10,10,0,0">
                    <StackPanel>
                        <!--BUTTON CHECK FOR UPDATES-->
                        <Button x:Name="btnCheckForUpdates" Style="{DynamicResource btnPopupMenuItem}" Click="btnCheckForUpdates_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🛠️" FontSize="14" Width="20" TextAlignment="Center"/>
                                <TextBlock Text="{x:Static languages:Lang.game_popup_more_check_for_updates}" FontSize="14" Padding="5,0,0,0" Foreground="Red"/>
                            </StackPanel>
                        </Button>
                        <!--BUTTON LOCATE GAME-->
                        <Button x:Name="btnLocateGame" Style="{DynamicResource btnPopupMenuItem}" Click="btnLocateGame_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📁" FontSize="14" Width="20" TextAlignment="Center"/>
                                <TextBlock Text="{x:Static languages:Lang.game_popup_more_locate_game}" FontSize="14" Padding="5,0,0,0"/>
                            </StackPanel>
                        </Button>
                        <!--BUTTON HD MODELS-->
                        <Button x:Name="btnUpdateOptions" Style="{DynamicResource btnPopupMenuItem}" Click="btnUpdateOptions_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📤" FontSize="14" Width="20" TextAlignment="Center"/>
                                <TextBlock Text="{x:Static languages:Lang.game_popup_more_update_options}" FontSize="14" Padding="5,0,0,0"/>
                                <TextBlock x:Name="updateOptionHolder" Text="Full Game" FontSize="14" Margin="5,0,0,0" Foreground="White"/>
                            </StackPanel>
                        </Button>
                        <!--BUTTON HD MODELS-->
                        <Button x:Name="btnHDMenu" Style="{DynamicResource btnPopupMenuItem}" Click="btnHDMenu_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🧑‍🚒" FontSize="14" Width="20" TextAlignment="Center"/>
                                <TextBlock Text="{x:Static languages:Lang.game_popup_more_hd_models}" FontSize="14" Padding="5,0,0,0"/>
                                <TextBlock x:Name="hdStatusHolder" Text="Enabled" FontSize="14" Margin="5,0,0,0" Foreground="Lime"/>
                            </StackPanel>
                        </Button>
                        <!--BUTTON AUTO-LOGIN-->
                        <Button x:Name="btnAutoLogin" Style="{DynamicResource btnPopupMenuItem}" Click="btnAutoLogin_Click" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔐" FontSize="14" Width="20" TextAlignment="Center"/>
                                <TextBlock Text="{x:Static languages:Lang.game_popup_more_auto_login}" FontSize="14" Padding="5,0,0,0"/>
                                <TextBlock x:Name="autoLoginStatusHolder" Text="Disabled" FontSize="14" Margin="5,0,0,0" Foreground="Red"/>
                            </StackPanel>
                        </Button>
                        <!--BUTTON AUTO-CLEAR CACHE-->
                        <Button x:Name="btnAutoClesarCache" Style="{DynamicResource btnPopupMenuItem}" Click="btnAutoClesarCache_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🌀" FontSize="14" Width="20" TextAlignment="Center"/>
                                <TextBlock Text="{x:Static languages:Lang.game_popup_more_auto_clear_cache}" FontSize="14" Padding="5,0,0,0"/>
                                <TextBlock x:Name="cacheStatusHolder" Text="Off" FontSize="14" Margin="5,0,0,0" Foreground="Red"/>
                            </StackPanel>
                        </Button>
                        <!--BUTTON INTERFACE LANGUAGE-->
                        <Button x:Name="btnInterfaceLanguage" Style="{DynamicResource btnPopupMenuItem}" Click="btnInterfaceLanguage_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🌏" FontSize="14" Width="20" TextAlignment="Center"/>
                                <TextBlock Text="{x:Static languages:Lang.game_popup_more_select_language}" FontSize="14" Padding="5,0,0,0"/>
                                <TextBlock x:Name="selectedLangHolder" Text="English US" FontSize="14" Margin="5,0,0,0" Foreground="#FF00CAFF"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
                <!--SERVERS STATUS-->
                <StackPanel Orientation="Vertical" Margin="0,0,0,15">
                    <StackPanel VerticalAlignment="Top">
                        <TextBlock Text="{x:Static languages:Lang.game_popup_more_server_status_title}" HorizontalAlignment="Left" VerticalAlignment="Top" Foreground="#FFDEDEDE" FontWeight="Bold" Margin="15,0,0,0" FontSize="13"/>
                        <Border BorderBrush="#FF4A4A4A" BorderThickness="0,0,0,1" VerticalAlignment="Top" Height="1" Margin="10,10,15,0"/>
                    </StackPanel>
                    <ScrollViewer Style="{DynamicResource ScrollViewerOne}" MaxHeight="115">
                        <StackPanel x:Name="spRealmsStatus"/>
                    </ScrollViewer>
                </StackPanel>
            </StackPanel>
            <!--UPDATE OPTIONS SUBMENU-->
            <StackPanel x:Name="spUpdateOptionsMenu" ClipToBounds="True" Background="#F4171717" Visibility="Hidden">
                <StackPanel VerticalAlignment="Top" Margin="0,0,0,15">
                    <TextBlock Text="{x:Static languages:Lang.game_popup_more_update_options_title}" HorizontalAlignment="Left" VerticalAlignment="Top" Foreground="#FFDEDEDE" FontWeight="Bold" Margin="15,15,0,0" FontSize="13"/>
                    <Border BorderBrush="#FF4A4A4A" BorderThickness="0,0,0,1" VerticalAlignment="Top" Height="1" Margin="5,10,5,0"/>
                </StackPanel>
                <Button x:Name="btnUpdateOptionsFull" Style="{DynamicResource btnPopupMenuItem}" Click="btnUpdateOptionsFull_Click">
                    <TextBlock Text="{x:Static languages:Lang.game_popup_more_toggle_full_game}" FontSize="14" Padding="5,0,0,0"/>
                </Button>
                <Button x:Name="btnUpdateOptionsOnlyUpdates" Style="{DynamicResource btnPopupMenuItem}" Click="btnUpdateOptionsOnlyUpdates_Click">
                    <TextBlock Text="{x:Static languages:Lang.game_popup_more_toggle_only_updates}" FontSize="14" Padding="5,0,0,0"/>
                </Button>
            </StackPanel>
            <!--LANGUAGE SELECTION SUBMENU-->
            <StackPanel x:Name="spLanguageSelection" ClipToBounds="True" Background="#F4171717" Visibility="Hidden">
                <StackPanel VerticalAlignment="Top">
                    <TextBlock Text="{x:Static languages:Lang.game_popup_more_select_language_title}" HorizontalAlignment="Left" VerticalAlignment="Top" Foreground="#FFDEDEDE" FontWeight="Bold" Margin="15,15,0,0" FontSize="13"/>
                    <Border BorderBrush="#FF4A4A4A" BorderThickness="0,0,0,1" VerticalAlignment="Top" Height="1" Margin="5,10,5,0"/>
                    <ScrollViewer Style="{DynamicResource ScrollViewerOne}"  Margin="10,10,0,0" Height="220">
                        <StackPanel x:Name="spLanguages"/>
                    </ScrollViewer>
                </StackPanel>
            </StackPanel>
            <!--HD CLIENT SUBMENU-->
            <StackPanel x:Name="spHDClientMenu" ClipToBounds="True" Background="#F4171717" Visibility="Hidden">
                <StackPanel VerticalAlignment="Top" Margin="0,0,0,15">
                    <TextBlock Text="{x:Static languages:Lang.game_popup_more_hd_client_title}" HorizontalAlignment="Left" VerticalAlignment="Top" Foreground="#FFDEDEDE" FontWeight="Bold" Margin="15,15,0,0" FontSize="13"/>
                    <Border BorderBrush="#FF4A4A4A" BorderThickness="0,0,0,1" VerticalAlignment="Top" Height="1" Margin="5,10,5,0"/>
                </StackPanel>
                <Button x:Name="btnHDEnable" Style="{DynamicResource btnPopupMenuItem}" Click="btnHDEnable_Click">
                    <TextBlock Text="{x:Static languages:Lang.game_popup_more_toggle_enable}" FontSize="14" Padding="5,0,0,0"/>
                </Button>
                <Button x:Name="btnHDDisable" Style="{DynamicResource btnPopupMenuItem}" Click="btnHDDisable_Click">
                    <TextBlock Text="{x:Static languages:Lang.game_popup_more_toggle_disable}" FontSize="14" Padding="5,0,0,0"/>
                </Button>
            </StackPanel>
            <!--CLEAR CACHE SUBMENU-->
            <StackPanel x:Name="spClearCacheMenu" ClipToBounds="True" Background="#F4171717" Visibility="Hidden">
                <StackPanel VerticalAlignment="Top" Margin="0,0,0,15">
                    <TextBlock Text="{x:Static languages:Lang.game_popup_more_clear_cache_title}" HorizontalAlignment="Left" VerticalAlignment="Top" Foreground="#FFDEDEDE" FontWeight="Bold" Margin="15,15,0,0" FontSize="13"/>
                    <Border BorderBrush="#FF4A4A4A" BorderThickness="0,0,0,1" VerticalAlignment="Top" Height="1" Margin="5,10,5,0"/>
                </StackPanel>
                <Button x:Name="btnClearCacheOn" Style="{DynamicResource btnPopupMenuItem}" Click="btnClearCacheOn_Click">
                    <TextBlock Text="{x:Static languages:Lang.game_popup_more_toggle_on}" FontSize="14" Padding="5,0,0,0"/>
                </Button>
                <Button x:Name="btnClearCacheOff" Style="{DynamicResource btnPopupMenuItem}" Click="btnClearCacheOff_Click">
                    <TextBlock Text="{x:Static languages:Lang.game_popup_more_toggle_off}" FontSize="14" Padding="5,0,0,0"/>
                </Button>
            </StackPanel>
            <!--AUTO LOGIN SUBMENU-->
            <StackPanel x:Name="spAutoLoginMenu" ClipToBounds="True" Background="#F4171717" Visibility="Hidden">
                <StackPanel VerticalAlignment="Top" Margin="0,0,0,15">
                    <TextBlock Text="{x:Static languages:Lang.game_popup_more_auto_login_title}" HorizontalAlignment="Left" VerticalAlignment="Top" Foreground="#FFDEDEDE" FontWeight="Bold" Margin="15,15,0,0" FontSize="13"/>
                    <Border BorderBrush="#FF4A4A4A" BorderThickness="0,0,0,1" VerticalAlignment="Top" Height="1" Margin="5,10,5,0"/>
                </StackPanel>
                <Button x:Name="btnAutoLoginOn" Style="{DynamicResource btnPopupMenuItem}" Click="btnAutoLoginOn_Click">
                    <TextBlock Text="{x:Static languages:Lang.game_popup_more_toggle_on}" FontSize="14" Padding="5,0,0,0"/>
                </Button>
                <Button x:Name="btnAutoLoginOff" Style="{DynamicResource btnPopupMenuItem}" Click="btnAutoLoginOff_Click">
                    <TextBlock Text="{x:Static languages:Lang.game_popup_more_toggle_off}" FontSize="14" Padding="5,0,0,0"/>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
