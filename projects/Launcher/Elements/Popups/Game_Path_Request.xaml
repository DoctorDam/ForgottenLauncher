<Border x:Class="Forgotten_Land_Launcher.Elements.Popups.Game_Path_Request"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:languages="clr-namespace:Forgotten_Land_Launcher.Languages"
        Background="#F90E0E0E" CornerRadius="7" RenderOptions.BitmapScalingMode="HighQuality">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="25,25,25,25">
        <Image Width="25" Height="25" Source="/Forgotten Land Launcher;component/Assets/icons/icon_warning_1_a.png"/>
        <TextBlock Text="{x:Static languages:Lang.game_popup_path_request_message}" Foreground="#FFE28E5E" FontWeight="Bold" FontSize="14" Margin="0,15,0,0"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            
            <Button x:Name="btnBrowse" Style="{DynamicResource btnNewMessage}" Content="{x:Static languages:Lang.general_button_browse_game}" 
                Padding="15,10,15,10" Background="#FF008E6A" BorderBrush="{x:Null}" BorderThickness="0,0,0,0" 
                Foreground="#FFE8E8E8" FontWeight="Bold" Cursor="Hand" Margin="0,15,0,0" Width="120" Click="btnBrowse_Click"/>
            
            <Button x:Name="btnExit" Style="{DynamicResource btnNewMessage}" Content="{x:Static languages:Lang.general_button_exit}" 
                Padding="15,10,15,10" Background="#FF8E5500" BorderBrush="{x:Null}" BorderThickness="0,0,0,0" 
                Foreground="#FFE8E8E8" FontWeight="Bold" Cursor="Hand" Margin="15,15,0,0" Width="120" Click="btnExit_Click"/>
            
        </StackPanel>
    </StackPanel>
</Border>
