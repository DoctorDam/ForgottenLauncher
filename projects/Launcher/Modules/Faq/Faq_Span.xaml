<UserControl x:Class="Forgotten_Land_Launcher.Modules.Faq.Faq_Span"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" Width="870" Foreground="#D9D9D9D9" Loaded="UserControl_Loaded">
    <Grid>
        <StackPanel>
            <Button x:Name="btnFaqTitle" Style="{DynamicResource buttonFaqTitle}" Background="#D81D1D1D" VerticalAlignment="Top" Padding="10,10,10,10" BorderBrush="{x:Null}" BorderThickness="0,0,0,0" HorizontalContentAlignment="Left" Cursor="Hand" Click="btnFaqTitle_Click">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Forgotten Land Launcher;component/Assets/icons/icon_book_1.png" Height="20" VerticalAlignment="Center"/>
                    <TextBlock x:Name="faqTitleHolder" Text="Question title" FontWeight="Bold" FontSize="14" Foreground="#D9CAC65F" Margin="7,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <TextBlock x:Name="faqTextHolder" Text="Lorem ipsum dolor sit amet, consectetur adipiscing elit. Aenean sit amet mollis urna, sit amet tempor eros. Etiam eu elit in dui dictum bibendum. Nulla condimentum vestibulum enim. Lorem ipsum dolor sit amet, consectetur adipiscing elit. Phasellus interdum neque eu felis ullamcorper, at dictum elit hendrerit. Nulla facilisi. Duis vel dapibus quam. Maecenas suscipit cursus porttitor." TextWrapping="Wrap" TextTrimming="CharacterEllipsis" Margin="10,10,10,10"/>
        </StackPanel>
    </Grid>
</UserControl>
