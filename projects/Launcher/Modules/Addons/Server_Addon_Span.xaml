<UserControl x:Class="Forgotten_Land_Launcher.Modules.Addons.Server_Addon_Span"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:languages="clr-namespace:Forgotten_Land_Launcher.Languages"
             Foreground="DarkGray"
             mc:Ignorable="d" Width="860" Height="120" Loaded="UserControl_Loaded">
    <Grid>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
            <Border CornerRadius="7" Width="100" Height="100" BorderThickness="1,1,1,1" BorderBrush="#FF797979">
                <Border.Background>
                    <ImageBrush x:Name="pictureHolder" Stretch="UniformToFill"/>
                </Border.Background>
            </Border>
            <StackPanel Orientation="Vertical" Margin="20,0,0,0" VerticalAlignment="Top">
                <TextBlock x:Name="nameHolder" Text="Addon Name" Foreground="DarkGray" FontSize="16"/>
                <TextBlock Margin="0,5,0,0" Foreground="#FF988D69">
                    <Run Text="{x:Static languages:Lang.general_text_addon_size}"/>
                    <Run x:Name="sizeHolder" Text="0 kb"/>
                </TextBlock>
                <TextBlock x:Name="descriptionHolder" Text="Description..." Margin="0,5,0,0" Foreground="DarkGray" Width="540" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxHeight="50"/>
            </StackPanel>
        </StackPanel>
        <StackPanel Orientation="Vertical" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,15,0">
            <Button x:Name="ButtonInstall" Style="{DynamicResource buttonStyle4d}" Content="Install" Height="25" Width="100" Click="ButtonInstall_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
