<Border x:Class="Forgotten_Land_Launcher.Modules.Account_Inventory.Inventory_Reward"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d" Width="130" Height="150" Loaded="UserControl_Loaded" 
        Padding="0,0,0,0" Background="#FF151515" CornerRadius="7" BorderThickness="0" BorderBrush="#FF2F2F2F">
    <Grid>
        <TextBlock x:Name="titleHolder" Text="Item Name" Foreground="DarkOrange" HorizontalAlignment="Center" FontSize="11" Margin="0,10,0,0" TextTrimming="CharacterEllipsis" FontWeight="Bold" VerticalAlignment="Top" Width="115" TextAlignment="Center"/>
        <Button Cursor="Hand" Style="{DynamicResource inventoryItemButton}" Width="127" Height="113" Click="Button_Click" BorderBrush="{x:Null}" BorderThickness="0,0,0,0" VerticalAlignment="Bottom">
            <Button.Background>
                <ImageBrush x:Name="pictureHolder" Stretch="UniformToFill"/>
            </Button.Background>
            <Grid/>
        </Button>
    </Grid>
</Border>
