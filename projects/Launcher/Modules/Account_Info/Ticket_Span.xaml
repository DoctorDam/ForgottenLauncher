<Button x:Class="Forgotten_Land_Launcher.Modules.Account_Info.Ticket_Span"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        mc:Ignorable="d" RenderOptions.BitmapScalingMode="HighQuality"
        d:DesignHeight="20" d:DesignWidth="580" Foreground="#FFBDBDBD"
        Background="#00DDDDDD" BorderBrush="{x:Null}" BorderThickness="0,0,0,0" 
        Cursor="Hand" Margin="0,5,0,5" Loaded="Button_Loaded" Click="Button_Click"
        Style="{DynamicResource accountInfoTicketButton}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="145"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <!--FIRST COLUMN-->
        <Border Grid.Column="0" BorderBrush="#FF2D2D2D" BorderThickness="0,0,1,0">
            <StackPanel Margin="5,0,0,0" Orientation="Horizontal">
                <Image x:Name="statusIconHolder" Source="/Forgotten Land Launcher;component/Assets/icons/icon_clock_1_a.png" Width="15" VerticalAlignment="Center"/>
                <TextBlock x:Name="statusTextHolder" Text="Status.." VerticalAlignment="Center" Margin="5,0,0,0"/>
            </StackPanel>
        </Border>
        <!--SECOND COLUMN-->
        <Border Grid.Column="1" BorderBrush="#FF2D2D2D" BorderThickness="0,0,1,0">
            <StackPanel Margin="5,0,0,0" Orientation="Horizontal">
                <Image x:Name="raceIconHolder" Source="/Forgotten Land Launcher;component/Assets/races/race_human_female.jpg" Width="15" VerticalAlignment="Center"/>
                <!--<Image x:Name="classIconHolder" Source="/Forgotten Land Launcher;component/Assets/classes/class_mage.jpg" Width="15" VerticalAlignment="Center" Margin="5,0,0,0"/>-->
                <TextBlock x:Name="charNameHolder" Text="Player" VerticalAlignment="Center" Margin="5,0,0,0" FontWeight="Bold"/>
            </StackPanel>
        </Border>
        <!--THIRD COLUMN-->
        <Border Grid.Column="2" BorderBrush="#FF2D2D2D" BorderThickness="0,0,1,0">
            <StackPanel Margin="5,0,0,0" Orientation="Horizontal">
                <Image Source="/Forgotten Land Launcher;component/Assets/icons/icon_calendar_2_a.png" Width="15" VerticalAlignment="Center"/>
                <TextBlock x:Name="lastModifiedTimeHolder" Text="29 Nov 2023 at 15:30" VerticalAlignment="Center" Margin="5,0,0,0"/>
            </StackPanel>
        </Border>
        <!--FOURTH COLUMN-->
        <Border Grid.Column="3" BorderBrush="#FF2D2D2D" BorderThickness="0,0,0,0">
            <StackPanel Margin="5,0,0,0" Orientation="Horizontal">
                <Image Source="/Forgotten Land Launcher;component/Assets/icons/icon_email_2_a.png" Width="15" VerticalAlignment="Center"/>
                <TextBlock x:Name="messageHolder" Text="......." VerticalAlignment="Center" Margin="5,0,0,0" TextTrimming="CharacterEllipsis" Width="185"/>
            </StackPanel>
        </Border>
    </Grid>
</Button>
