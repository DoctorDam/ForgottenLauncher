<UserControl x:Class="Forgotten_Land_Launcher.Modules.Online_Players.Player_Row"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Forgotten_Land_Launcher.Modules.Online_Players"
             mc:Ignorable="d" Height="40" MinWidth="500" FontSize="14"
             Foreground="#FF848484" Margin="0,0,0,10" Loaded="UserControl_Loaded">
    <Border x:Name="mainBorder" CornerRadius="5" Background="#FF252525" Padding="15,0,15,0">
        <Grid>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="14,0,0,0">
                <Border CornerRadius="3" Height="18" Width="18" BorderThickness="1,1,1,1" BorderBrush="#FF525252">
                    <Border.Background>
                        <ImageBrush x:Name="raceHolder" Stretch="Uniform"/>
                    </Border.Background>
                </Border>
                <Border CornerRadius="3" Margin="5,0,0,0" Height="18" Width="18" BorderThickness="1,1,1,1" BorderBrush="#FF525252">
                    <Border.Background>
                        <ImageBrush x:Name="classHolder" Stretch="Uniform"/>
                    </Border.Background>
                </Border>
                <TextBlock x:Name="nameHolder" Text="player" FontWeight="Bold" Margin="15,0,0,0"/>
                <TextBlock Margin="7,0,0,0">
                    <Run Text="Level"/>
                    <Run x:Name="levelHolder" Text="1"/>
                </TextBlock>
                <TextBlock x:Name="factionHolder" Text="(faction)" Margin="7,0,0,0"/>
                <TextBlock Margin="25,0,0,0">
                    <Run Text="Zone" FontWeight="Bold"/>
                    <Run x:Name="zoneHolder" Text=".." Foreground="#FFD2D2D2"/>
                </TextBlock>
            </StackPanel>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                <TextBlock>
                    <Run Text="Realm" FontWeight="Bold"/>
                    <Run x:Name="realmHolder" Text=".." Foreground="#FFD2D2D2"/>
                </TextBlock>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
