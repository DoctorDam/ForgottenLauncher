<Button x:Class="Forgotten_Land_Launcher.Modules.Discord.Discord_Widget"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:Spinners="clr-namespace:Forgotten_Land_Launcher.Elements.Spinners" 
        xmlns:languages="clr-namespace:Forgotten_Land_Launcher.Languages"
        Style="{DynamicResource btnDiscordWidget_A}"
        mc:Ignorable="d" 
        Padding="15,10,15,10" BorderBrush="{x:Null}" Background="#FF1D1D1D"
        Loaded="Button_Loaded" Click="Login_Discord_Widget_Button_Click">
    <Grid>
        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
            <Image Source="/Forgotten Land Launcher;component/Assets/icons/icon_discord_1_a.png" Width="45" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <StackPanel x:Name="spDiscordInfo" Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Foreground="#FFC7C7C7" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center">
                    <Run Text="#DISCORD -"/>
                    <Run x:Name="discordCount" Text="?" Foreground="White"/>
                    <Run Text="{x:Static languages:Lang.discord_widget_text_members_online}" Foreground="#FFFFDE00"/>
                </TextBlock>
                <TextBlock x:Name="serverName" Text="{x:Static languages:Lang.discord_widget_text_loading}" Foreground="#FFEEB652" VerticalAlignment="Center" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" Margin="0,3,0,0"/>
            </StackPanel>
        </StackPanel>
        <Viewbox x:Name="spinner" HorizontalAlignment="Center" Width="30" Visibility="Hidden">
            <Spinners:Dotted_Spinner/>
        </Viewbox>
    </Grid>
</Button>
