<UserControl x:Class="Forgotten_Land_Launcher.Modules.Discord.Member_Span"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Forgotten_Land_Launcher.Modules.Discord"
             mc:Ignorable="d" 
             d:DesignHeight="50" d:DesignWidth="935" Loaded="UserControl_Loaded" Margin="0,0,0,15" Width="935" Height="50">
    <StackPanel Orientation="Horizontal">
        <Ellipse x:Name="status1Holder" Width="10" Height="10" Fill="#FF13FF00" Margin="15,0,0,0"/>
        <Border Width="50" Height="50" CornerRadius="5,5,5,5" Margin="15,0,0,0">
            <Border.Background>
                <ImageBrush x:Name="avatarHolder" Stretch="Fill"/>
            </Border.Background>
        </Border>
        <TextBlock Margin="15,0,0,0" VerticalAlignment="Center">
            <Run x:Name="usernameHolder" Text="Username" Foreground="#FFE8E8E8" FontWeight="Bold" FontSize="16"/>
            <Run Text="-" Foreground="#FFE8E8E8" FontSize="16"/>
            <Run x:Name="status2Holder" Text="Idle" Foreground="#FFB3B3B3" FontSize="16"/>
            <Run x:Name="gamePrefix" Text="-" Foreground="#FFE8E8E8" FontSize="16"/>
            <Run x:Name="gameHolder" Text="playing World of Warcraft" Foreground="#FFFF9800" FontSize="16" FontStyle="Italic"/>
        </TextBlock>
    </StackPanel>
</UserControl>
