<Button x:Class="Forgotten_Land_Launcher.Modules.Private_Messages.Topic_Span"
        Style="{DynamicResource buttonTopicRow}"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d" RenderOptions.BitmapScalingMode="HighQuality"
        Foreground="#FF999999"
        Width="868" Height="80" Background="{x:Null}" Cursor="Hand" BorderBrush="{x:Null}" 
        BorderThickness="0,0,0,0" Loaded="Button_Loaded" Click="Button_Click">
    <Border Height="80" CornerRadius="10" Background="#3F000000" Width="868">
            <StackPanel Orientation="Horizontal">
                <Border Width="60" Height="60" CornerRadius="5" HorizontalAlignment="Left" Margin="10,0,0,0" Opacity="0.75">
                    <Border.Background>
                        <ImageBrush x:Name="avatarHolder" Stretch="UniformToFill"/>
                    </Border.Background>
                </Border>
                <StackPanel Margin="15,12,0,10" Orientation="Vertical">
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                        <Image x:Name="arrowIcon" Source="/Forgotten Land Launcher;component/Assets/icons/icon_arrow_right_1_a.png" Width="12" Margin="0,0,5,0" RenderTransformOrigin="0.5,0.5"/>
                        <TextBlock FontSize="14" VerticalAlignment="Top">
                                <Run x:Name="receiverHolder" Text="Unknown" FontWeight="Bold" Foreground="DarkOrange"/>
                                <Run Text="-"/>
                                <Run x:Name="titleHolder" Text="Title" FontWeight="Bold"/>
                                <Run x:Name="dateHolder" Text="date edited" FontStyle="Italic" Foreground="#FF616161"/>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel x:Name="spSeen" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,0,10,0" Opacity="0.5">
                            <TextBlock Text="Seen" FontSize="14" FontStyle="Italic"/>
                        <Image Source="/Forgotten Land Launcher;component/Assets/icons/icon_checked_1.png" Width="12" Margin="5,1,0,0" Opacity="0.5"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock x:Name="messageHolder" Text="Duis lacinia, magna sit amet tincidunt fringilla, eros risus commodo ex, quis suscipit nunc felis venenatis elit. Quisque non tortor ac nisi maximus venenatis. Sed a est at elit placerat volutpat at et diam. Integer pulvinar convallis imperdiet. Aliquam erat volutpat. Duis blandit nulla a urna aliquam, id eleifend enim facilisis. Mauris ut ligula id risus cursus tincidunt. Donec aliquam sapien a diam dignissim ullamcorper." 
                               TextTrimming="CharacterEllipsis" TextWrapping="Wrap" Height="40" Margin="0,5,0,0" Width="770" HorizontalAlignment="Left"/>
                </StackPanel>
            </StackPanel>
        </Border>
</Button>
