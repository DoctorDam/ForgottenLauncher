<UserControl x:Class="Forgotten_Land_Launcher.Modules.Private_Messages.Message_Span"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Forgotten_Land_Launcher.Modules.Private_Messages"
             mc:Ignorable="d" Loaded="UserControl_Loaded">
    <StackPanel Orientation="Vertical">
        <StackPanel Orientation="Horizontal">
            <TextBlock x:Name="senderHolder" Foreground="DarkOrange" FontWeight="Bold" Text="AUTHOR"/>
            <TextBlock x:Name="dateHolder" Text="03.12.2023" Foreground="#FF636363" FontStyle="Italic" Margin="7,0,0,0"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
            <Border CornerRadius="5" Width="60" Height="60" VerticalAlignment="Top" BorderThickness="1,1,1,1" 
                    BorderBrush="{Binding BorderBrush, ElementName=messageHolder}">
                <Border.Background>
                    <ImageBrush x:Name="avatarHolder" Stretch="UniformToFill"/>
                </Border.Background>
            </Border>
            <StackPanel Orientation="Vertical" Margin="5,0,0,0">
                <TextBox x:Name="messageHolder" Style="{DynamicResource inputTextBox2}" AcceptsTab="True" 
                    HorizontalAlignment="Left" Foreground="#FF999999" VerticalAlignment="Top" TextWrapping="Wrap"
                    Background="#3F000000" Width="790" FontSize="14" BorderBrush="#3F2F2F2F" SelectionBrush="#FF75652C"
                    FontFamily="Fira Sans Condensed" MaxLength="2500"
                    Text="Lorem ipsum dolor sit amet, consectetur adipiscing elit. Praesent sed tempor mauris, non pulvinar magna. Vestibulum in augue dapibus nunc vestibulum suscipit. Vivamus commodo massa eu quam dignissim venenatis. Quisque sed urna tellus. Sed eget nibh ipsum. Ut eu tellus et eros dignissim porta vehicula ut magna. Donec eleifend, nibh in imperdiet dignissim, diam lorem condimentum massa, eget consequat nisl justo ut felis." 
                    AcceptsReturn="True" Padding="10,10,10,10" IsEnabled="False" MinHeight="60"/>
            </StackPanel>
        </StackPanel>
    </StackPanel>
</UserControl>
