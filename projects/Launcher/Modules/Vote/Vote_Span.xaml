<UserControl x:Class="Forgotten_Land_Launcher.Modules.Vote.Vote_Span"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:languages="clr-namespace:Forgotten_Land_Launcher.Languages"
             mc:Ignorable="d" Width="860" Height="120" Loaded="UserControl_Loaded">
    <Grid>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
            <Border CornerRadius="5" Width="100" Height="100">
                <Border.Background>
                    <ImageBrush x:Name="imageHolder" Stretch="Uniform"/>
                </Border.Background>
            </Border>
            <StackPanel Orientation="Vertical" Margin="20,0,0,0" VerticalAlignment="Center">
                <TextBlock x:Name="nameHolder" Text="Site Name" Foreground="DarkGray" FontSize="16" FontWeight="Bold"/>
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <Image Width="15" Height="15" Source="/Forgotten Land Launcher;component/Assets/icons/icon_clock_1_a.png" VerticalAlignment="Center"/>
                    <TextBlock Foreground="#FF988D69" Margin="5,0,0,0">
                        <Run Text="{x:Static languages:Lang.vote_text_cooldown_left}"/>
                        <Run x:Name="cooldownHolder" Text="0s" FontWeight="Bold" Foreground="#FF9A9790"/>
                    </TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <Image Width="15" Height="15" Source="/Forgotten Land Launcher;component/Assets/icons/icon_silver_coin_1_a.png" VerticalAlignment="Center"/>
                    <TextBlock Foreground="#FF988D69" VerticalAlignment="Center" Margin="5,0,0,0">
                        <Run Text="{x:Static languages:Lang.vote_text_points_reward}"/>
                        <Run x:Name="pointsRewardHolder" Text="0" FontWeight="Bold" Foreground="#FF9A9790"/>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </StackPanel>
        <StackPanel Orientation="Vertical" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,15,0">
            <Button x:Name="voteButton" Style="{DynamicResource buttonStyle4}" Content="{x:Static languages:Lang.vote_button}" Height="25" Width="80" Background="#FF498628" Margin="0,0,0,10" IsEnabled="False" Click="voteButton_Click"/>
            <!--<Button x:Name="voteButton" Style="{DynamicResource buttonStyle5}" Content="REMOVE" Height="25" Width="80" Background="#FF862828" Click="removeButton_Click"/>-->
        </StackPanel>
    </Grid>
</UserControl>
