<UserControl x:Class="Forgotten_Land_Launcher.Modules.Ladderboard.Ladderboard_Row"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" Width="873" Foreground="#FF999999" Loaded="UserControl_Loaded">
    <Grid Width="873">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="40"/>
            <ColumnDefinition/>
            <ColumnDefinition Width="60"/>
            <ColumnDefinition Width="60"/>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="25"/>
        </Grid.RowDefinitions>
        <!--POSITION-->
        <Border Grid.Column="0" Grid.Row="0">
            <TextBlock x:Name="positionHolder" Text="#" FontWeight="Bold" VerticalAlignment="Center" Margin="5,0,0,0"/>
        </Border>
        <!--NAME-->
        <Border Grid.Column="1" Grid.Row="0">
            <TextBlock x:Name="nameHolder" Text="Name" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="#FFE0E0E0" FontWeight="Bold"/>
        </Border>
        <!--RACE-->
        <Border Grid.Column="2" Grid.Row="0">
            <Border Width="16" Height="16">
                <Border.Background>
                    <ImageBrush x:Name="raceHolder" ImageSource="/Forgotten Land Launcher;component/Assets/races/race_human_male.jpg"/>
                </Border.Background>
            </Border>
        </Border>
        <!--CLASS-->
        <Border Grid.Column="3" Grid.Row="0">
            <Border Width="16" Height="16">
                <Border.Background>
                    <ImageBrush x:Name="classHolder" ImageSource="/Forgotten Land Launcher;component/Assets/classes/class_warrior.jpg"/>
                </Border.Background>
            </Border>
        </Border>
        <!--TODAY KILLS-->
        <Border Grid.Column="4" Grid.Row="0">
            <TextBlock x:Name="todayKillsHolder" Text="0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
        <!--YESTERDAY KILLS-->
        <Border Grid.Column="5" Grid.Row="0">
            <TextBlock x:Name="yesterdayKillsHolder" Text="0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
        <!--TOTAL KILLS-->
        <Border Grid.Column="6" Grid.Row="0">
            <TextBlock x:Name="totalKillsHolder" Text="0" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#FFFF7500" FontWeight="Bold"/>
        </Border>
        <!--REALM-->
        <Border Grid.Column="7" Grid.Row="0">
            <TextBlock x:Name="realmHolder" Text="?" HorizontalAlignment="Center" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="180"/>
        </Border>
    </Grid>
</UserControl>
