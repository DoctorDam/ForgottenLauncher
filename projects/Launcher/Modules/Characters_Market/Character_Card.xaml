<UserControl x:Class="Forgotten_Land_Launcher.Modules.Characters_Market.Character_Card"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:languages="clr-namespace:Forgotten_Land_Launcher.Languages"
             mc:Ignorable="d" Margin="0,0,10,10" Loaded="UserControl_Loaded">
    <Border x:Name="cardBorder" CornerRadius="7" Background="#FF1D1D1D" BorderBrush="#FF333333" BorderThickness="1,1,1,1">
        <Grid>
            <Border CornerRadius="7">
                <Border.Background>
                    <ImageBrush x:Name="BackgroundHolder" Stretch="UniformToFill" Opacity="0.20"/>
                </Border.Background>
            </Border>
            <StackPanel Margin="15,0,15,15" Orientation="Vertical">
                <Border CornerRadius="5" HorizontalAlignment="Center" Margin="0,7,0,0" Padding="10,3,10,3" Background="#3F000000">
                    <TextBlock>
                        <Run Text="{x:Static languages:Lang.page_characters_market_card_text_expires_in}" Foreground="#FF999999"/>
                        <Run x:Name="expiringTimeHolder" Foreground="#FFD6D6D6"/>
                    </TextBlock>
                </Border>
                <Grid HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,10,0,0">
                    <Border CornerRadius="10" Width="45" Height="45" BorderThickness="1,1,1,1" BorderBrush="#FF9E9E9E">
                        <Border.Background>
                            <ImageBrush x:Name="RaceAvatarHolder" ImageSource="/Forgotten Land Launcher;component/Assets/races/race_bloodelf_female.jpg" Stretch="UniformToFill"/>
                        </Border.Background>
                    </Border>
                    <Border CornerRadius="5" Width="18" Height="18" BorderThickness="1,1,1,1" BorderBrush="#FF272727" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,-1,-5,-5">
                        <Border.Background>
                            <ImageBrush x:Name="ClassAvatarHolder" ImageSource="/Forgotten Land Launcher;component/Assets/classes/class_warlock.jpg"/>
                        </Border.Background>
                    </Border>
                </Grid>
                <Border CornerRadius="7" Background="#E51D1D1D" Padding="10" BorderBrush="#FF272727" BorderThickness="1,1,1,1" HorizontalAlignment="Center" VerticalAlignment="Top" Width="190" Margin="0,10,0,0">
                    <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top">
                        <TextBlock x:Name="CharNameHolder" Text="Playername" Foreground="White" FontWeight="Bold" FontSize="14" Width="150" TextTrimming="CharacterEllipsis" HorizontalAlignment="Center" TextAlignment="Center"/>
                        <TextBlock Foreground="#FFD6D6D6" Width="150" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,5,0,0" TextAlignment="Center">
                            <Run x:Name="CharRaceHolder" Text="Race" Foreground="#FF999999"/>
                            <Run x:Name="CharClassHolder" Text="Class"/>
                        </TextBlock>
                        <StackPanel x:Name="spLevel" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                            <Image Source="/Forgotten Land Launcher;component/Assets/icons/icon_levelup_1_a.png" Width="10" VerticalAlignment="Center" Height="12"/>
                            <TextBlock Foreground="#FFD6D6D6" TextTrimming="CharacterEllipsis" Margin="5,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Left">
                                <Run Text="{x:Static languages:Lang.page_characters_market_card_text_level}"/>
                                <Run x:Name="CharLevelHolder" Text="0" FontWeight="Bold"/>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel x:Name="spProfessions" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                            <Image Source="/Forgotten Land Launcher;component/Assets/icons/icon_location_1.png" Width="10" VerticalAlignment="Center" Height="12"/>
                            <TextBlock x:Name="RealmHolder" Text="Realm name" Foreground="#FFD6D6D6" TextTrimming="CharacterEllipsis" Margin="5,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0" HorizontalAlignment="Center">
                    <Button x:Name="ButtonMoreInfo" Content="{x:Static languages:Lang.page_characters_market_button_more_info}" Style="{DynamicResource buttonMoreInfo}" Click="ButtonMoreInfo_Click" Width="80" Background="#FF131313"/>
                    <Button x:Name="ButtonCancelSale" Content="{x:Static languages:Lang.page_characters_market_button_cancel_sale}" Style="{DynamicResource buttonCancelSale}" Width="80" Margin="10,0,0,0" Visibility="Collapsed" Click="ButtonCancelSale_Click"/>
                </StackPanel>
                <StackPanel x:Name="spCost" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,10,0,0">
                    <TextBlock x:Name="priceTypeHolder" Text="{x:Static languages:Lang.page_characters_market_card_text_fixed_price}" Foreground="#FF999999" Margin="0,0,5,0" FontWeight="Bold"/>
                    <Image x:Name="priceIcon" Source="/Forgotten Land Launcher;component/Assets/icons/icon_gold_coin_1_a.png" Width="15" VerticalAlignment="Center"/>
                    <TextBlock x:Name="PriceHolder" Text="0" Margin="5,0,0,0" VerticalAlignment="Center" Foreground="White" FontWeight="Bold"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
