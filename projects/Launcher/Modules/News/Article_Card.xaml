<Button x:Class="Forgotten_Land_Launcher.Modules.News.Article_Card"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d" 
        HorizontalAlignment="Left" Margin="0,0,20,20" BorderBrush="{x:Null}" 
        Background="#00000000" Style="{DynamicResource homeCenterBlockArticle}" 
        Padding="0,0,0,0" BorderThickness="0,0,0,0" Width="290" Height="330"
        Loaded="Button_Loaded" Click="Button_Click">
    <StackPanel Orientation="Vertical" Width="290" Height="330">
        <Border x:Name="border" CornerRadius="10" Padding="0" Height="170">
            <Grid>
                <Border Name="mask" Background="Black" CornerRadius="{Binding ElementName=border, Path=CornerRadius}"/>
                <Grid>
                    <Grid.OpacityMask>
                        <VisualBrush Visual="{Binding ElementName=mask}"/>
                    </Grid.OpacityMask>
                    <MediaElement x:Name="movieLoader" LoadedBehavior="Manual" MediaEnded="movieLoader_MediaEnded" Width="290" Height="170" IsMuted="True" Stretch="UniformToFill"/>
                    <Image x:Name="imageLoader" Width="290" Height="170" Stretch="UniformToFill"/>
                </Grid>
            </Grid>
        </Border>
        <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
            <Image Source="/Forgotten Land Launcher;component/Assets/logos/wow_logo_og.png" Width="20" Height="20" VerticalAlignment="Center"/>
            <TextBlock Text="WORLD OF WARCRAFT" FontWeight="Bold" VerticalAlignment="Center" Margin="5,0,0,0" Foreground="#FF999999"/>
        </StackPanel>
        <TextBlock x:Name="titleHolder" Text="Duis nec leo nec nisi pretium feugiat et nec dui." Margin="0,10,0,0" 
               FontWeight="Bold" Foreground="#FFE0E0E0" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" FontSize="15" MaxHeight="45"/>
        <TextBlock x:Name="contentHolder" Text="Duis nec leo nec nisi pretium feugiat et nec dui. Donec eget ipsum vel est interdum accumsan. Sed ut mattis lacus. " 
               Margin="0,3,0,0" Foreground="#FFFFB400" TextWrapping="Wrap" Height="40" TextTrimming="CharacterEllipsis" FontSize="13"/>
        <TextBlock Text="News" 
               Margin="0,0,0,0" Foreground="#FF999999" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" FontSize="13"/>
    </StackPanel>
</Button>
