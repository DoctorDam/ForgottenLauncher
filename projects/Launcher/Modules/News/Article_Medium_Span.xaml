<Button x:Class="Forgotten_Land_Launcher.Modules.News.Article_Medium_Span"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:languages="clr-namespace:Forgotten_Land_Launcher.Languages"
        Style="{DynamicResource buttonNewsRowA}" 
        mc:Ignorable="d" Width="935" Height="150" Loaded="Button_Loaded" Click="Button_Click">
    <Grid>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <Border x:Name="border" CornerRadius="10" Padding="0" Width="220" Height="130">
                <Grid>
                    <Border Name="mask" Background="Black" CornerRadius="{Binding ElementName=border, Path=CornerRadius}"/>
                    <Grid>
                        <Grid.OpacityMask>
                            <VisualBrush Visual="{Binding ElementName=mask}"/>
                        </Grid.OpacityMask>
                        <MediaElement x:Name="movieLoader" LoadedBehavior="Manual" MediaEnded="movieLoader_MediaEnded" Width="220" Height="130" IsMuted="True" Stretch="UniformToFill"/>
                        <Image x:Name="imageLoader" Width="220" Height="130" Stretch="UniformToFill"/>
                    </Grid>
                </Grid>
            </Border>
            <StackPanel Orientation="Vertical" Margin="0,10,0,5">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Forgotten Land Launcher;component/Assets/logos/wow_logo_og.png" Width="20" Height="20" Margin="15,0,0,0"/>
                    <TextBlock x:Name="titleHolder" Text="Article Title" Margin="5,0,0,0" Foreground="#FFC8C8C8" FontWeight="Bold" VerticalAlignment="Center" Width="645" TextTrimming="CharacterEllipsis" FontSize="14"/>
                </StackPanel>
                <TextBlock x:Name="contentHolder" Text="Article content.." TextWrapping="Wrap" TextTrimming="CharacterEllipsis" Foreground="#FF969696" Width="670" HorizontalAlignment="Left" Margin="15,5,0,0" Height="80" FontSize="14"/>
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <TextBlock Text="{x:Static languages:Lang.article_text_on_date}" Foreground="#FFC8C8C8" FontSize="14" Margin="15,0,0,0" FontWeight="Bold"/>
                        <TextBlock x:Name="dateHolder" Text="10 October 2023" Foreground="#FFC8C8C8" FontSize="14" Margin="5,0,0,0"/>
                        <TextBlock Text="-" Margin="5,0,0,0" FontSize="14" Foreground="#FFC8C8C8"/>
                        <TextBlock Text="{x:Static languages:Lang.article_text_posted_by}" Foreground="#FFC8C8C8" FontSize="14" Margin="5,0,0,0" FontWeight="Bold"/>
                        <TextBlock x:Name="authorHolder" Text="CyberMist" Foreground="#FFFFBB00" FontSize="14" Margin="5,0,0,0"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </StackPanel>
    </Grid>
</Button>
