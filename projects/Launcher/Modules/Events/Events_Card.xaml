<Border x:Class="Forgotten_Land_Launcher.Modules.Events.Events_Card"
        x:Name="mainBorder"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:languages="clr-namespace:Forgotten_Land_Launcher.Languages"
        mc:Ignorable="d" 
        Width="935" Height="250" Margin="0,0,0,15" CornerRadius="5"
        BorderThickness="0" BorderBrush="{x:Null}" Loaded="mainBorder_Loaded">
    <Border.Background>
        <ImageBrush x:Name="bannerHolder" Stretch="UniformToFill"/>
    </Border.Background>
    <Grid>
        <Border CornerRadius="5" Background="#D8100A01" VerticalAlignment="Top" BorderThickness="0,0,0,1" BorderBrush="#7F353535">
            <StackPanel Orientation="Horizontal" Margin="10,10,10,10">
                <Image Source="/Forgotten Land Launcher;component/Assets/logos/wow_logo_og.png" Width="30" Height="30"/>
                <TextBlock x:Name="titleHolder" Text="MY EVENT TITLE" Foreground="#FFC3C3C3" FontSize="15" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0,0,0"/>
                <Ellipse Width="10" Height="10" Margin="10,0,0,0" Fill="Lime" VerticalAlignment="Center"/>
                <TextBlock Foreground="#FFC3C3C3" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="14">
                    <Run Text="{x:Static languages:Lang.general_text_event_active_until}"/>
                    <Run x:Name="expiryDateHolder" Text="01 November 3000"/>
                </TextBlock>

            </StackPanel>
        </Border>

        <TextBlock x:Name="contentHolder" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="25,0,0,15" Foreground="#FFE6E6E6" Text="Proin egestas vestibulum eros id mattis. Morbi vulputate arcu velit, ac vulputate urna lacinia condimentum asdasd asdad wdaw da wdsd sadaw daw dasd asd" FontSize="15" FontWeight="DemiBold" Width="730" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxHeight="50" />

        <Button x:Name="btnReadMore" Background="#D8171717" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,25,15" BorderBrush="#FF2D2D2D" Padding="15,5,15,5" Style="{DynamicResource btnEventReadMore}" Click="btnReadMore_Click">
            <StackPanel>
                <TextBlock x:Name="textBlock" Foreground="#FF9A9A9A" Text="{x:Static languages:Lang.general_button_readmore}" Padding="5,0,5,0"/>
                <Rectangle Height="1" Stroke="{Binding Foreground, ElementName=textBlock}" StrokeDashArray="2 2" VerticalAlignment="Bottom" Margin="0,1,0,0" />
            </StackPanel>
        </Button>
    </Grid>
</Border>
