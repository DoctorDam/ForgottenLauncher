<Button x:Class="Forgotten_Land_Launcher.Modules.Shop.Shop_Card"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        RenderOptions.BitmapScalingMode="HighQuality"
        Style="{DynamicResource buttonShopArticle}"
        mc:Ignorable="d" Width="205" Height="200"
        Background="#FF1A1C1D" BorderBrush="#00707070" Foreground="#FFD0D0D0"
        Margin="0,0,10,10" FontWeight="Bold"
        Cursor="Hand" Loaded="Button_Loaded">
    <StackPanel Orientation="Vertical">
        <TextBlock x:Name="titleHolder" Text="Shop Article Title" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" TextWrapping="Wrap" MaxHeight="32" TextAlignment="Center" Margin="0,0,0,10" Width="160"/>
        <Border CornerRadius="7" Width="160" Height="100">
            <Border.Background>
                <ImageBrush x:Name="pictureHolder" Stretch="UniformToFill"/>
            </Border.Background>
        </Border>
        <StackPanel Orientation="Horizontal" Margin="0,15,0,0" HorizontalAlignment="Center">
            <StackPanel x:Name="spDPPrice" Orientation="Horizontal" Margin="0,0,10,0">
                <Image Source="/Forgotten Land Launcher;component/Assets/icons/icon_gold_coin_1_a.png" Width="15"/>
                <TextBlock x:Name="dpPriceHolder" Text="0" Margin="5,0,0,0"/>
            </StackPanel>
            <StackPanel x:Name="spVPPrice" Orientation="Horizontal">
                <Image Source="/Forgotten Land Launcher;component/Assets/icons/icon_silver_coin_1_a.png" Width="15"/>
                <TextBlock x:Name="vpPriceHolder" Text="0" Margin="5,0,0,0"/>
            </StackPanel>
            <StackPanel x:Name="spFREE">
                <TextBlock Text="FREE" Foreground="#FF6ED270"/>
            </StackPanel>
        </StackPanel>
    </StackPanel>
</Button>
