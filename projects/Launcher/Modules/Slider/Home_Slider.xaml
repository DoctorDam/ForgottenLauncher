<UserControl x:Class="Forgotten_Land_Launcher.Modules.Slider.Home_Slider"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:languages="clr-namespace:Forgotten_Land_Launcher.Languages"
             mc:Ignorable="d" Height="240"
             Loaded="UserControl_Loaded">
    <Grid>
        <Grid x:Name="ArtworkBackgroundGrid">
            <Border Background="#FF191919" CornerRadius="3" BorderThickness="0.5"/>
            <Border x:Name="bSlider" CornerRadius="5" BorderThickness="0.5" Width="910">
                <Border.Background>
                    <ImageBrush x:Name="ArtworkBackgroundHolder" Stretch="UniformToFill"/>
                </Border.Background>
            </Border>
        </Grid>
        <TextBlock x:Name="titleHolder" HorizontalAlignment="Center" VerticalAlignment="Top" Foreground="#FFF7A900" Text="SLIDE TITLE" FontWeight="Medium" FontSize="35" MaxWidth="500" TextTrimming="CharacterEllipsis" TextAlignment="Center" Margin="0,80,0,0">
            <TextBlock.Effect>
                <DropShadowEffect BlurRadius="1" ShadowDepth="1"/>
            </TextBlock.Effect>
        </TextBlock>
        <TextBlock x:Name="descriptionHolder" HorizontalAlignment="Center" VerticalAlignment="Top" Foreground="#FFF5D2B6" Text=" SLIDE TITLE SLIDE TITLE SLIDE TITLE SLIDE TITLE SLIDE SLIDE TITLE SLIDE TITLE SLIDE TITLE SLIDE TITLE SLIDE SLIDE TITLE SLIDE TITLE SLIDE TITLE SLIDE TITLE SLIDE" Margin="0,125,0,0" FontFamily="Beaufort for LOL" TextAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="500" TextWrapping="Wrap" Height="34" FontSize="13">
            <TextBlock.Effect>
                <DropShadowEffect BlurRadius="1" ShadowDepth="1"/>
            </TextBlock.Effect>
        </TextBlock>
        <Button x:Name="redirectButton" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,165,0,0" Style="{DynamicResource sliderRedirectButton}" Content="{x:Static languages:Lang.slider_button_learn_more}" FontWeight="Medium" Height="32" FontSize="11" Click="redirectButton_Click">
            <Button.Effect>
                <DropShadowEffect ShadowDepth="1" Opacity="0.25"/>
            </Button.Effect>
        </Button>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,10">
            <!--NAVIGATE LEFT-->
            <Button x:Name="btnSliderNavLeft" Style="{DynamicResource sliderNavButton}" Click="LeftButton_Click">
                <TextBlock Text="❮" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20" FontWeight="Bold"/>
            </Button>
            <!--DOTS-->
            <StackPanel x:Name="spSliderDots" Orientation="Horizontal" Margin="15,0,15,0" VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="600"/>
            <!--NAVIGATE RIGHT-->
            <Button x:Name="btnSliderNavRight" Style="{DynamicResource sliderNavButton}" Click="RightButton_Click">
                <TextBlock Text="❯" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20" FontWeight="Bold"/>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
