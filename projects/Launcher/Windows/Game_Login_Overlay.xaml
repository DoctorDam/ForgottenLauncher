<Window x:Class="Forgotten_Land_Launcher.Windows.Game_Login_Overlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Forgotten_Land_Launcher.Windows"
        xmlns:properties="clr-namespace:Forgotten_Land_Launcher.Properties"
        xmlns:languages="clr-namespace:Forgotten_Land_Launcher.Languages"
        xmlns:Spinners="clr-namespace:Forgotten_Land_Launcher.Elements.Spinners"
        mc:Ignorable="d" Topmost="True" WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" ShowInTaskbar="False"
        Title="{Binding ServerName, Source={x:Static properties:Settings.Default}, StringFormat={}{0} - Game Login Overlay}"
        Background="#CC000000" Loaded="Window_Loaded" Foreground="White" FontFamily="Beaufort for LOL">
    <Grid>
        <Border CornerRadius="15" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="100,100,100,100" Padding="50,25,50,25" Background="#F20E0E0E" BorderBrush="#FF303030" BorderThickness="1,1,1,1">
            <StackPanel Orientation="Vertical">
                <TextBlock x:Name="waitPlaceholder" Text="{x:Static languages:Lang.window_game_login_text_wait}" TextWrapping="Wrap" HorizontalAlignment="Center" Width="250" TextAlignment="Center" Foreground="#FFFFC600" FontWeight="Bold"/>
                <Viewbox x:Name="loadingSpinner" Width="20" Margin="0,10,0,0">
                    <Spinners:Dotted_Spinner />
                </Viewbox>
                <Border CornerRadius="5,5,5,5" BorderBrush="#FF404040" BorderThickness="1,1,1,1" Width="60" Height="60" Cursor="Hand" Margin="0,15,0,0">
                    <Border.Background>
                        <ImageBrush x:Name="avatarHolder" ImageSource="/Forgotten Land Launcher;component/Assets/default_avatar.jpg" Stretch="UniformToFill"/>
                    </Border.Background>
                </Border>
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Archivo Black" FontSize="18" FontWeight="Bold" Margin="0,15,0,0">
                    <Run x:Name="serverNameHolder" Text="Server Name -"/>
                    <Run x:Name="usernameHolder" Text="UNKNOWN"/>
                </TextBlock>
                <Button x:Name="ButtonLogin" Margin="0,15,0,0" Style="{DynamicResource loginSignInButton}" Content="{x:Static languages:Lang.login_window_button_sign_in}" Click="ButtonLogin_Click" Background="#FFFFC700" FontWeight="DemiBold" FontSize="13" FontFamily="Archivo Black" IsEnabled="False"/>
                <Button x:Name="ButtonContinueMnaually" Style="{DynamicResource btnTosLink}" Content="{x:Static languages:Lang.window_game_login_overlay_button_continue}" Margin="0,10,0,0" Click="ButtonContinueMnaually_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
