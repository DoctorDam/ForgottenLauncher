<Window x:Class="Forgotten_Land_Launcher.Launcher"
        xmlns:Popups="clr-namespace:Forgotten_Land_Launcher.Elements.Popups"
        xmlns:Button_Elements="clr-namespace:Forgotten_Land_Launcher.Elements.Buttons"
        xmlns:Pages="clr-namespace:Forgotten_Land_Launcher.Pages"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:properties="clr-namespace:Forgotten_Land_Launcher.Properties"
        xmlns:languages="clr-namespace:Forgotten_Land_Launcher.Languages"
        xmlns:Spinners="clr-namespace:Forgotten_Land_Launcher.Elements.Spinners"
        mc:Ignorable="d" WindowStartupLocation="CenterScreen" WindowStyle="None" 
        AllowsTransparency="True" ResizeMode="CanMinimize" RenderOptions.BitmapScalingMode="HighQuality"
        Background="{x:Null}" Foreground="#FF999999" FontFamily="Fira Sans Condensed"
        Title="{Binding ServerName, Source={x:Static properties:Settings.Default}, StringFormat={}{0} - Launcher}"
        Height="780" Width="1300" 
        Loaded="Window_Loaded">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="60" ResizeBorderThickness="1" GlassFrameThickness="0" 
                      CornerRadius="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>
    <Border x:Name="border1" Width="1280" Height="760" Background="#FF1b1b1b" BorderBrush="#FF252525" BorderThickness="1.5" CornerRadius="10">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" BlurRadius="15" Opacity="0.8" Direction="315" Color="Black"/>
        </Border.Effect>
        <Border CornerRadius="9">
            <Border.Background>
                <ImageBrush ImageSource="/Forgotten Land Launcher;component/Assets/backgrounds/launcher_background.jpg" Stretch="UniformToFill" Opacity="0.10"/>
            </Border.Background>
            <Grid x:Name="mainGrid">
                <Grid WindowChrome.IsHitTestVisibleInChrome="True" VerticalAlignment="Top">
                    <TextBlock Text="{Binding ServerName, Source={x:Static properties:Settings.Default}, StringFormat={}{0}}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="20,3,0,0" FontWeight="Bold" Foreground="#FFCECECE"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" FlowDirection="RightToLeft">
                        <Button Style="{DynamicResource windowExitButton}" x:Name="windowExitButton" Content="X" Width="40" Height="30" Background="#FF292929"
                            BorderBrush="{x:Null}" Foreground="#FF6B6B6B" FontFamily="Microsoft Sans Serif" FontSize="14" Click="windowExitButton_Click"/>
                        <Button Style="{DynamicResource windowMinimizeButton}" x:Name="windowMinimizeButton" Content="⎯" Width="40" Height="30" Background="#FF292929" 
                            BorderBrush="{x:Null}" Foreground="#FF6B6B6B" FontFamily="Microsoft Sans Serif" FontSize="14" Click="windowMinimizeButton_Click"/>
                    </StackPanel>
                </Grid>

                <!--LEFT SIDE GRID-->
                <Grid x:Name="LefSideMenuGrid" Width="300" HorizontalAlignment="Left" DockPanel.Dock="Top" VerticalAlignment="Top" Margin="0,40,0,0">
                    <StackPanel Orientation="Vertical">
                        <Border CornerRadius="5" Background="#BF1D1D1D" Margin="15,0,15,15" BorderBrush="#FF252525" BorderThickness="1,1,1,1">
                            <StackPanel Orientation="Vertical">
                                <Border BorderThickness="0,0,0,1" BorderBrush="#FF303030" Background="#26000000">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal">
                                            <StackPanel Orientation="Horizontal">
                                                <Button x:Name="btnAvatar" Style="{DynamicResource avatarButton}" Width="60" Height="60" HorizontalAlignment="Left" Margin="10,10,10,10" BorderBrush="{x:Null}" BorderThickness="0,0,0,0" Padding="0,0,0,0" Background="{x:Null}" Click="btnAvatar_Click">
                                                    <Border CornerRadius="5,5,5,5" BorderBrush="#FF404040" BorderThickness="1,1,1,1" Width="60" Height="60" Cursor="Hand">
                                                        <Border.Background>
                                                            <ImageBrush x:Name="avatarHolder" ImageSource="/Forgotten Land Launcher;component/Assets/default_avatar.jpg" Stretch="UniformToFill"/>
                                                        </Border.Background>
                                                    </Border>
                                                </Button>
                                                <StackPanel Margin="0,10,10,10">
                                                    <TextBlock x:Name="usernameHolder" Text="username" Foreground="#FFD5D5D5" FontSize="14" FontWeight="Medium" Padding="3,0,0,0" Width="155" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock x:Name="rankHolder" Text="rank" Padding="3,3,5,1" Foreground="#FFFF7F7F" FontSize="13"/>
                                                    <Border CornerRadius="5" Margin="0,3,0,0" Background="#99303030" HorizontalAlignment="Left">
                                                        <TextBlock Margin="5,3,5,0">
                                                            <Run Text="AKA:"/>
                                                            <Run x:Name="nicknameHolder" Text="not set.."/>
                                                        </TextBlock>
                                                    </Border>
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                        <Button x:Name="btnLogout" Style="{DynamicResource buttonLogoutOuter}" Background="#FF303030" HorizontalAlignment="Right" BorderBrush="{x:Null}" BorderThickness="0,0,0,0" Cursor="Hand" Click="btnLogout_Click">
                                            <Button Style="{DynamicResource buttonLogoutInner}" x:Name="buttonLogout" Width="15" HorizontalAlignment="Right" BorderBrush="{x:Null}" Margin="3,0,2,0" Cursor="Hand" Height="18">
                                                <Button.Background>
                                                    <ImageBrush ImageSource="/Forgotten Land Launcher;component/Assets/icons/icon_exit_1_a.png" Stretch="Uniform"/>
                                                </Button.Background>
                                            </Button>
                                        </Button>
                                    </Grid>
                                </Border>
                                <Border BorderThickness="0,0,0,1" BorderBrush="#FF303030">
                                    <Grid>
                                        <StackPanel Orientation="Vertical" Margin="10,15,10,15">
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="/Forgotten Land Launcher;component/Assets/icons/icon_gold_coin_1_a.png" Width="20" HorizontalAlignment="Left"/>
                                                <Border CornerRadius="5" VerticalAlignment="Center" Background="#99303030" Margin="10,0,0,0">
                                                    <TextBlock Foreground="Gainsboro" FontSize="14" Padding="10,5,10,3">
                                                        <Run x:Name="donatePointsHolder" Text="0"/>
                                                        <Run x:Name="dpNameHolder" Text="{x:Static languages:Lang.home_profile_donate_points}"/>
                                                    </TextBlock>
                                                </Border>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,7,0,0">
                                                <Image Source="/Forgotten Land Launcher;component/Assets/icons/icon_silver_coin_1_a.png" Width="20" HorizontalAlignment="Left"/>
                                                <Border CornerRadius="5" VerticalAlignment="Center" Background="#99303030" Margin="10,0,0,0">
                                                    <TextBlock Foreground="Gainsboro" FontSize="14" Padding="10,5,10,3">
                                                        <Run x:Name="votePointsHolder" Text="0"/>
                                                        <Run Text="{x:Static languages:Lang.home_profile_vote_points}"/>
                                                    </TextBlock>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>
                                        <Grid x:Name="gridReloadCurrencies" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,15,0">
                                            <Button x:Name="btnReloadCurrencies" Style="{DynamicResource ButtonReloadCurrencies}" Width="16" Height="16" Opacity="0.5" Click="btnReloadCurrencies_Click">
                                                <Image Source="/Forgotten Land Launcher;component/Assets/icons/icon_reload_1.png"/>
                                            </Button>
                                            <Viewbox x:Name="reloadCurrenciesSpinner" Width="16" Visibility="Hidden">
                                                <Spinners:Dotted_Spinner />
                                            </Viewbox>
                                        </Grid>
                                    </Grid>
                                </Border>
                                <Border BorderThickness="0,0,0,1" Background="#07FFA400">
                                    <StackPanel x:Name="spProfileButtons" Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button x:Name="btnProfile" Width="32" Height="32" Margin="10,17,5,15" Click="btnNav_Click" BorderBrush="{x:Null}" 
                                                BorderThickness="0,0,0,0" Style="{DynamicResource btnProfileMenu}" Cursor="Hand">
                                            <Button.Background>
                                                <ImageBrush ImageSource="/Forgotten Land Launcher;component/Assets/icons/icon_profile_1_a.png"/>
                                            </Button.Background>
                                        </Button>
                                        <Button x:Name="btnInventory" Width="32" Height="32" Margin="10,17,5,15" Click="btnNav_Click" BorderBrush="{x:Null}" 
                                                BorderThickness="0,0,0,0" Style="{DynamicResource btnProfileMenu}" Cursor="Hand">
                                            <Button.Background>
                                                <ImageBrush ImageSource="/Forgotten Land Launcher;component/Assets/icons/icon_inventory_1_a.png"/>
                                            </Button.Background>
                                        </Button>
                                        <Button x:Name="btnMessages" Width="32" Height="32" Margin="10,17,5,15" Click="btnNav_Click" BorderBrush="{x:Null}" 
                                                BorderThickness="0,0,0,0" Style="{DynamicResource btnProfileMenu}" Cursor="Hand">
                                            <Button.Background>
                                                <ImageBrush ImageSource="/Forgotten Land Launcher;component/Assets/icons/icon_messages_1_a.png"/>
                                            </Button.Background>
                                        </Button>
                                        <Button x:Name="btnLoginRewards" Width="32" Height="32" Margin="10,17,5,15" Click="btnNav_Click" BorderBrush="{x:Null}" 
                                                BorderThickness="0,0,0,0" Style="{DynamicResource btnProfileMenu}" Cursor="Hand">
                                            <Button.Background>
                                                <ImageBrush ImageSource="/Forgotten Land Launcher;component/Assets/icons/icon_calendar_1_a.png"/>
                                            </Button.Background>
                                        </Button>
                                        <Button x:Name="btnRedeemGift" Width="32" Height="32" Margin="10,17,5,15" Click="btnRedeemGift_Click" BorderBrush="{x:Null}" 
                                                BorderThickness="0,0,0,0" Style="{DynamicResource btnProfileMenu}" Cursor="Hand">
                                            <Button.Background>
                                                <ImageBrush ImageSource="/Forgotten Land Launcher;component/Assets/icons/icon_gift_1_a.png"/>
                                            </Button.Background>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border CornerRadius="5" Background="#D81D1D1D" Margin="15,0,15,0" BorderBrush="#FF252525" BorderThickness="1,1,1,1" Height="325">
                            <ScrollViewer Style="{DynamicResource ScrollViewerOne}">
                                <!--LEFT SIDE MENU BUTTONS-->
                                <StackPanel x:Name="spLeftMenu" Orientation="Vertical">
                                    <Button_Elements:LeftMenuButton x:Name="lmButtonHome" DisplayText="{x:Static languages:Lang.left_menu_button_home}"
                                        IconA="/Forgotten Land Launcher;component/Assets/icons/icon_home_1_a.png" 
                                        IconH="/Forgotten Land Launcher;component/Assets/icons/icon_home_1_h.png" Click="btnNav_Click"/>
                                    <Button_Elements:LeftMenuButton x:Name="lmButtonForums" DisplayText="{x:Static languages:Lang.left_menu_button_forum}"
                                        IconA="/Forgotten Land Launcher;component/Assets/icons/icon_forums_1_a.png" 
                                        IconH="/Forgotten Land Launcher;component/Assets/icons/icon_forums_1_h.png" Click="lsButtonForums_Click"/>
                                    <Button_Elements:LeftMenuButton x:Name="lmButtonShop" DisplayText="{x:Static languages:Lang.left_menu_button_shop}"
                                        IconA="/Forgotten Land Launcher;component/Assets/icons/icon_cart_1_a.png" 
                                        IconH="/Forgotten Land Launcher;component/Assets/icons/icon_cart_1_h.png" Click="btnNav_Click"/>
                                    <Button_Elements:LeftMenuButton x:Name="lmButtonCharactersMarket" DisplayText="{x:Static languages:Lang.left_menu_button_characters_market}"
                                        IconA="/Forgotten Land Launcher;component/Assets/icons/icon_warrior_1_a.png" 
                                        IconH="/Forgotten Land Launcher;component/Assets/icons/icon_warrior_1_h.png" Click="btnNav_Click"/>
                                    <Button_Elements:LeftMenuButton x:Name="lmButtonAddons" DisplayText="{x:Static languages:Lang.left_menu_button_addons}"
                                        IconA="/Forgotten Land Launcher;component/Assets/icons/icon_books_1_a.png" 
                                        IconH="/Forgotten Land Launcher;component/Assets/icons/icon_books_1_h.png" Click="btnNav_Click"/>
                                    <Button_Elements:LeftMenuButton x:Name="lmButtonVote" DisplayText="{x:Static languages:Lang.left_menu_button_vote}"
                                        IconA="/Forgotten Land Launcher;component/Assets/icons/icon_like_1_a.png" 
                                        IconH="/Forgotten Land Launcher;component/Assets/icons/icon_like_1_h.png" Click="btnNav_Click"/>
                                    <Button_Elements:LeftMenuButton x:Name="lmButtonOnlinePlayers" DisplayText="{x:Static languages:Lang.left_menu_button_online_players}"
                                        IconA="/Forgotten Land Launcher;component/Assets/icons/icon_ribbon_1_a.png" 
                                        IconH="/Forgotten Land Launcher;component/Assets/icons/icon_ribbon_1_h.png" Click="btnNav_Click"/>
                                    <Button_Elements:LeftMenuButton x:Name="lmButtonLadderboard" DisplayText="{x:Static languages:Lang.left_menu_button_ladderboard}"
                                        IconA="/Forgotten Land Launcher;component/Assets/icons/icon_ribbon_1_a.png" 
                                        IconH="/Forgotten Land Launcher;component/Assets/icons/icon_ribbon_1_h.png" Click="btnNav_Click"/>
                                    <Button_Elements:LeftMenuButton x:Name="lmButtonFAQ" DisplayText="{x:Static languages:Lang.left_menu_button_faq}"
                                        IconA="/Forgotten Land Launcher;component/Assets/icons/icon_faq_1_a.png" 
                                        IconH="/Forgotten Land Launcher;component/Assets/icons/icon_faq_1_h.png" Click="btnNav_Click"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                    </StackPanel>
                </Grid>

                <!--RIGHT SIDE GRID-->
                <Grid x:Name="RightSideGrid" Width="960" Margin="5,40,0,0" HorizontalAlignment="Right" VerticalAlignment="Top">

                    <!--NAVBAR MENU-->
                    <Border Height="45" CornerRadius="5" VerticalAlignment="Top" Width="950" HorizontalAlignment="Left">
                        <Border.Background>
                            <LinearGradientBrush EndPoint="0.9,1" StartPoint="0,0">
                                <GradientStop Color="#FF303030"/>
                                <GradientStop Color="#FF1B1B1B" Offset="1"/>
                                <GradientStop Color="#FF282828" Offset="0.5"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <StackPanel x:Name="spNavButtons" Orientation="Horizontal" HorizontalAlignment="Left">
                                <Button x:Name="btnNavHome" Style="{DynamicResource buttonNavbar}" Content="{x:Static languages:Lang.home_navbar_button_home}" Click="btnNav_Click"/>
                                <Button x:Name="btnNavNews" Style="{DynamicResource buttonNavbar}" Content="{x:Static languages:Lang.home_navbar_button_news}" Click="btnNav_Click"/>
                                <Button x:Name="btnNavEvents" Style="{DynamicResource buttonNavbar}" Content="{x:Static languages:Lang.home_navbar_button_events}" Click="btnNav_Click"/>
                                <Button x:Name="btnNavDiscord" Style="{DynamicResource buttonNavbar}" Content="{x:Static languages:Lang.home_navbar_button_discord}" Click="btnNav_Click"/>
                                <Button x:Name="btnNavChangelog" Style="{DynamicResource buttonNavbar}" Content="{x:Static languages:Lang.home_navbar_button_changelog}" Click="btnNav_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!--PAGE HOLDER-->
                    <Grid x:Name="pageHolderGrid" Margin="0,70,0,0" Width="960" HorizontalAlignment="Left">
                        <Pages:Home x:Name="pageHome" Visibility="Visible"/>
                        <Pages:News x:Name="pageNews" Visibility="Hidden" HorizontalAlignment="Left" />
                        <Pages:Article_Viewer x:Name="pageArticleViewer" Visibility="Hidden" HorizontalAlignment="Left" />
                        <Pages:Events x:Name="pageEvents" Visibility="Hidden" HorizontalAlignment="Left" />
                        <Pages:Discord x:Name="pageDiscord" Visibility="Hidden" HorizontalAlignment="Left" />
                        <Pages:Changelog x:Name="pageChangelogs" Visibility="Hidden" HorizontalAlignment="Left" />
                        <Pages:Login_Rewards x:Name="pageLoginRewards" Visibility="Hidden" HorizontalAlignment="Left" />
                        <Pages:Account_Info x:Name="pageAccountInfo" Visibility="Hidden" HorizontalAlignment="Left" />
                        <Pages:Account_Inventory x:Name="pageAccountInventory" Visibility="Hidden" HorizontalAlignment="Left" />
                        <Pages:Private_Messages x:Name="pagePrivateMessages" Visibility="Hidden" HorizontalAlignment="Left" />
                        <Pages:Private_Message_New x:Name="pageNewMessage" Visibility="Hidden" HorizontalAlignment="Left" />
                        <Pages:Private_Message_View x:Name="pagePrivateMessageView" Visibility="Hidden" HorizontalAlignment="Left" />
                        <Pages:Shop x:Name="pageShop" Visibility="Hidden" HorizontalAlignment="Left" />
                        <Pages:Characters_Market x:Name="pageCharactersMarket" Visibility="Hidden" HorizontalAlignment="Left" />
                        <Pages:Faq x:Name="pageFaq" Visibility="Hidden" HorizontalAlignment="Left" />
                        <Pages:Addons x:Name="pageAddons" Visibility="Hidden" HorizontalAlignment="Left" />
                        <Pages:Vote x:Name="pageVote" Visibility="Hidden" HorizontalAlignment="Left" />
                        <Pages:Online_Players x:Name="pageOnlinePlayers" Visibility="Hidden" HorizontalAlignment="Left" />
                        <Pages:Ladderboard x:Name="pageLadderboard" Visibility="Hidden" HorizontalAlignment="Left" />
                    </Grid>
                </Grid>

                <!--GAME BUTTON-->
                <Grid x:Name="gridGameButton" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="0,0,0,25" 
                      Panel.ZIndex="9002">
                    <StackPanel Orientation="Vertical">
                        <StackPanel Orientation="Horizontal" Margin="15,0,0,0">
                            <!--GAME BUTTON-->
                            <Button_Elements:GameButtonPlay Visibility="Visible" x:Name="btnPlay" Click="btnPlay_Click" />
                            <Button_Elements:GameButtonUpdate Visibility="Collapsed" x:Name="btnUpdate" Click="btnUpdate_Click"/>
                            <Button_Elements:GameButtonCancelUpdate Visibility="Collapsed" x:Name="btnCancelUpdate" Click="btnCancelUpdate_Click"/>
                            <!--MORE BUTTON-->
                            <Button_Elements:GameButtonMore x:Name="btnGameMoreOptions" Margin="1,0,0,0" Click="btnGameMoreOptions_Click" />
                        </StackPanel>
                        <Grid>
                            <StackPanel x:Name="spChecksum" Visibility="Hidden" Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Margin="0,20,0,0" FontSize="14" Foreground="#FFCCCCCC">
                                <Run Text="Verifying"/>
                                <Run x:Name="checksumFile" Text="file name" Foreground="White"/>
                                </TextBlock>
                            </StackPanel>
                            <StackPanel x:Name="spDownloadDetails" Visibility="Hidden" Orientation="Horizontal" Margin="0,20,0,0" HorizontalAlignment="Right">
                                <Image Source="/Forgotten Land Launcher;component/Assets/icons/icon_download_1_a.png" Width="15" Margin="0,0,0,3"/>
                                <TextBlock Visibility="Visible" FontSize="14" Margin="10,0,0,0" Foreground="#FFCCCCCC">
                                    <Run x:Name="dlTotalProgress" Text="0%" FontWeight="Bold"/>
                                    <Run Text="-"/>
                                    <Run x:Name="dlTotalDownloaded" Text="0 KB"/>
                                    <Run Text="/"/>
                                    <Run x:Name="dlTotalToDownload" Text="0 KB"/>
                                    <Run x:Name="dlSpeed" Text="@0KB/s"/>
                                </TextBlock>
                                <TextBlock Visibility="Collapsed" Text="Ready to Play" FontWeight="Bold" FontSize="14"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Grid>

                <!--DOWNLOAD PROGRESS BAR-->
                <ProgressBar x:Name="downloadBar" Style="{DynamicResource ProgressBarStyle1}" VerticalAlignment="Bottom" 
                             HorizontalAlignment="Center" Width="1277" Height="10" BorderThickness="0,0,0,0" 
                             Background="#FF101010" Foreground="#FFFFB400" Visibility="Hidden" Value="55"/>

                <!--POPUP: DARKNESS FOG-->
                <Popups:Darkness_Fog x:Name="darknessFog" Visibility="Hidden" Panel.ZIndex="9000"/>

                <!--POPUP: GAME MORE OPTIONS-->
                <Popups:Game_More_Options x:Name="gameMoreOptions" Visibility="Hidden" Margin="15,0,0,119" VerticalAlignment="Bottom" HorizontalAlignment="Left" Panel.ZIndex="9001"/>

                <!--POPUP: GAME PATH NOT SET-->
                <Popups:Game_Path_Request x:Name="gamePathRequest" Visibility="Hidden" Panel.ZIndex="9002"/>

                <!--POPUP MESSAGE-->
                <ScrollViewer HorizontalAlignment="Right" VerticalAlignment="Top" Style="{DynamicResource ScrollViewerOne}" MaxHeight="700" Margin="0,25,0,0">
                    <StackPanel x:Name="spPopups" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                </ScrollViewer>

            </Grid>
        </Border>
    </Border>
</Window>
